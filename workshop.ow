        事件暴击 == 真;
        正在使用终极技能(事件玩家) == 真;
        正在使用辅助武器(事件玩家) == 真;
        正在使用主要武器(事件玩家) == 真;
        事件技能 == 按钮(主要攻击模式);
    }
    动作 {
        伤害(被攻击方, 攻击方, 乘(0.199999999999999, 事件伤害));
    }
}

规则 ("[widowmaker.opy]: Revert sniper damage falloff") {
    事件 {
        玩家造成伤害;
        双方;
        黑百合;
    }
    条件 {
        所用英雄(事件玩家) == 英雄(黑百合);
        正在使用辅助武器(事件玩家) == 真;
        正在使用主要武器(事件玩家) == 真;
        事件技能 == 按钮(主要攻击模式);
    }
    动作 {
        设置玩家变量(事件玩家, scoped_shot_distance, 相距距离(眼睛位置(攻击方), 被攻击方));
        设置玩家变量(事件玩家, ow2_scoped_damage_falloff_scalar, 加(乘(除(减((事件玩家).scoped_shot_distance, 50), 20), 0.5), 减(1, 除(减((事件玩家).scoped_shot_distance, 50), 20))));
        "Cap min/max scalar\nMax damage scalar"
        If(比较((事件玩家).ow2_scoped_damage_falloff_scalar, >, 1));
            设置玩家变量(事件玩家, ow2_scoped_damage_falloff_scalar, 1);
        Else If(比较((事件玩家).ow2_scoped_damage_falloff_scalar, <, 0.5));
            设置玩家变量(事件玩家, ow2_scoped_damage_falloff_scalar, 0.5);
        End;
        设置玩家变量(事件玩家, scoped_damage_base, 除(事件伤害, (事件玩家).ow2_scoped_damage_falloff_scalar));
        设置玩家变量(事件玩家, ow1_scoped_damage_falloff_scalar, 加(乘(除(减((事件玩家).scoped_shot_distance, 70), 30), 0.3), 减(1, 除(减((事件玩家).scoped_shot_distance, 70), 30))));
        "Cap min/max scalar\nMax damage scalar"
        If(比较((事件玩家).ow1_scoped_damage_falloff_scalar, >, 1));
            设置玩家变量(事件玩家, ow1_scoped_damage_falloff_scalar, 1);
        Else If(比较((事件玩家).ow1_scoped_damage_falloff_scalar, <, 0.3));
            设置玩家变量(事件玩家, ow1_scoped_damage_falloff_scalar, 0.3);
        End;
        设置玩家变量(事件玩家, expected_scoped_damage, 乘((事件玩家).scoped_damage_base, (事件玩家).ow1_scoped_damage_falloff_scalar));
        伤害(被攻击方, 攻击方, 取整(减((事件玩家).expected_scoped_damage, 事件伤害), 上));
    }
}

