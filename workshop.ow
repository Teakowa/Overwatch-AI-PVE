		创建HUD文本(事件玩家, 空, 自定义字符串("正在使用终极技能 = {0}", 正在使用终极技能(事件玩家)), 空, 右边, 1, 空, 颜色(白色), 空, 字符串, 默认可见度);
		创建HUD文本(事件玩家, 空, 自定义字符串("正在使用主要武器 = {0}", 正在使用主要武器(事件玩家)), 空, 右边, 1, 空, 颜色(白色), 空, 字符串, 默认可见度);
		"hudSubheader(eventPlayer, \"isUsingAbility1() = {}\".format(eventPlayer.isUsingAbility1()), HudPosition.RIGHT, 1, Color.WHITE, HudReeval.STRING)"
		创建HUD文本(事件玩家, 空, 自定义字符串("正在使用技能 1 = {0}", 正在使用技能 1(事件玩家)), 空, 右边, 1, 空, 颜色(白色), 空, 字符串, 默认可见度);
		创建HUD文本(事件玩家, 空, 自定义字符串("技能 1 冷却时间 = {0}", 技能冷却时间(事件玩家, 按钮(技能1))), 空, 右边, 1, 空, 颜色(白色), 空, 字符串, 默认可见度);
