		禁用 (所用英雄(攻击方) == 英雄(伊拉锐)) == 真;
		具有状态(被攻击方, 击晕) != 真;
	}

	动作
	{
		设置状态(被攻击方, 攻击方, 击晕, 0.800);
	}
}

