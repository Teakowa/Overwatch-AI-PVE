规则("[Global]Robot heroes array")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.Mechanical = 空数组;
		修改全局变量(Mechanical, 添加至数组, 英雄(回声));
		修改全局变量(Mechanical, 添加至数组, 英雄(D.Va));
		修改全局变量(Mechanical, 添加至数组, 英雄(奥丽莎));
