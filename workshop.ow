规则("[Doomfist] Seismic Slam upper")
{
	事件
	{
		玩家受到伤害;
		双方;
		全部;
	}

	条件
	{
		事件技能 == 按钮(技能1);
		(所用英雄(攻击方) == 英雄(末日铁拳)) == 真;
		事件技能 != 按钮(主要攻击模式);
		事件技能 != 按钮(辅助攻击模式);
		(所用英雄(被攻击方) == 英雄(奥丽莎) && (正在使用技能 1(被攻击方) || 正在使用终极技能(被攻击方))) == 假;
		(所用英雄(被攻击方) == 英雄(毛加) && 正在使用技能 1(被攻击方)) == 假;
	}

	动作
	{
		施加推力(事件玩家, 上, 7, 至玩家, 取消相反运动XYZ);
		施加推力(事件玩家, 地图矢量(后, 攻击方, 旋转), 5, 至地图, 取消相反运动XYZ);
		开始限制阈值(事件玩家, 0, 0, 0, 0, 0, 0);
		等待(0.800, 无视条件);
		停止限制阈值(事件玩家);
	}
}

规则("[doomfist/meteor.opy]: Deal OW1 Meteor Strike damage")
{
	事件
	{
		玩家造成伤害;
		双方;
		末日铁拳;
	}

	条件
	{
		事件技能 == 按钮(终极技能);
		"Only activate this rule when damage is dealt by inner ring (/2 accounts for damage reduction from armor, nanoboost, etc)"
		事件伤害 < 200;
	}

	动作
	{
		伤害(被攻击方, 攻击方, 取整(200 + 2.176 * (事件伤害 - 100) - 事件伤害, 上));
	}
}

