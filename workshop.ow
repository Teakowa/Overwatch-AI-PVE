规则 ("[Zarya]: will to win") {
    事件 {
        持续 - 每名玩家;
        双方;
        查莉娅;
    }
    条件 {
        首个((事件玩家).reset_pvar) == 假;
        在重生室中(事件玩家) == 假;
        所用英雄(事件玩家) == 英雄(查莉娅);
        数组中的值(全局.ZaryaBuff, 2) == 真;
        存活(事件玩家) == 真;
        首个((事件玩家).zarya_buff) == 真;
        生命值(事件玩家) <= 乘(最大生命值(事件玩家), 0.3);
    }
    动作 {
        大字体信息(事件玩家, 自定义字符串("胜利意志！"));
        设置状态(事件玩家, 空, 无敌, 1);
        设置状态(事件玩家, 空, 相移, 1);
        设置技能冷却(事件玩家, 按钮(技能1), 0);
        设置技能冷却(事件玩家, 按钮(技能2), 0);
        开始持续治疗(事件玩家, 事件玩家, 数组中的值(全局.ZaryaBuff, 3), 数组中的值(全局.ZaryaBuff, 4));
        在索引处设置玩家变量(事件玩家, zarya_buff, 1, 上一个持续治疗效果ID);
        等待直到 (死亡(事件玩家), 数组中的值(全局.ZaryaBuff, 3));
        停止持续治疗(数组中的值((事件玩家).zarya_buff, 1));
        在索引处设置玩家变量(事件玩家, zarya_buff, 0, 假);
        在索引处设置玩家变量(事件玩家, zarya_buff, 1, 空);
    }
}

