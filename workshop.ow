禁用 规则("Initialize Heors End")
{
	事件
	{
		持续 - 全局;
	}
}

规则("Changelog")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		游戏正在进行中 != 真;
		在重生室中(事件玩家) == 真;
	}

	动作
	{
		等待(0.160, 无视条件);
		调用子程序(changelogText);
		等待直到 (!在重生室中(事件玩家), 99999);
		消除HUD文本(事件玩家.ChangelogText1);
		消除HUD文本(事件玩家.ChangelogText2);
		禁用 消除所有HUD文本;
	}
}

规则("Changelog Content")
{
	事件
	{
		子程序;
		changelogText;
	}

	动作
	{
		创建HUD文本(事件玩家, 空, 空, 自定义字符串(" \r\n\r\n\r\n\n"), 左边, 0, 空, 空, 真, 可见和字符串, 始终不可见);
		事件玩家.ChangelogText1 = 上一个文本ID;
		If(所用英雄(事件玩家) == 英雄(D.Va));
			创建HUD文本(事件玩家, 空, 自定义字符串(" \r\n\r\n\n 非重装 AI 伤害减免 25%\r\n 重装 AI 最高伤害减免 40%\r\n 完整更新日志 workshop.codes/3TP7F/update-log\r\n 坐牢交流群: 361913638"), 自定义字符串(
				"\r\n●\"{0}\"\r\n*造成伤害 +25%\r\n*受到伤害 -30%\r\n{1} 防御矩阵\r\n 持续时间提高至 4 秒\r\n 完全充能时间由 6 秒降低至 3 秒\n\n※※离开重生室隐藏", 所用英雄(事件玩家),
				技能图标字符串(所用英雄(事件玩家), 按钮(辅助攻击模式))), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
