		事件玩家.is_using_uppercut != 假;
	}

	动作
	{
		播放效果(所有玩家(所有队伍), 爆炸声音, 所在队伍(事件玩家), 事件玩家, 100);
		播放效果(所有玩家(所有队伍), 负面状态施加声音, 所在队伍(事件玩家), 事件玩家, 100);
		播放效果(所有玩家(所有队伍), 环状爆炸声音, 所在队伍(事件玩家), 事件玩家, 100);
	}
}

