规则 ("[Ramattra]: Pain endures") {
    事件 {
        玩家造成最后一击;
        双方;
        拉玛刹;
    }
    条件 {
        终极技能充能百分比(事件玩家) != 100;
        正在使用终极技能(事件玩家) == 真;
        或(比较(事件技能, ==, 按钮(终极技能)), 比较(事件技能, ==, 按钮(技能1))) == 真;
    }
    动作 {
        设置终极技能充能(事件玩家, 加(终极技能充能百分比(事件玩家), 25));
        等待(0.3, 无视条件);
    }
}

规则 ("[Ramattra]: block") {
    事件 {
        玩家受到伤害;
        双方;
        拉玛刹;
    }
    条件 {
        或(正在使用技能 1(事件玩家), 正在使用终极技能(事件玩家)) == 真;
        正在使用辅助武器(事件玩家) == 真;
        (事件玩家).ram_block_damage <= 首个(全局.Ram_Annihilation);
        类型的生命值(事件玩家, 生命值) <= 加(首个((事件玩家).custom_hp_pvar), 50);
    }
    动作 {
        修改玩家变量(事件玩家, ram_block_damage, 加, 事件伤害);
        设置玩家变量(事件玩家, hudText, 自定义字符串("{0}/{1}", 取整((事件玩家).ram_block_damage, 下), 首个(全局.Ram_Annihilation)));
    }
}

规则 ("[Ramattra]: block HP") {
    事件 {
        持续 - 每名玩家;
        双方;
        拉玛刹;
    }
    条件 {
        首个(全局.Ram_Annihilation) != 0;
        (事件玩家).ram_block_damage != 0;
        (事件玩家).ram_block_damage >= 首个(全局.Ram_Annihilation);
    }
    动作 {
        为玩家添加生命池(事件玩家, 生命值, If-Then-Else(比较((事件玩家).ram_block_damage, >=, 首个(全局.Ram_Annihilation)), 首个(全局.Ram_Annihilation), (事件玩家).ram_block_damage), 假, 假);
        设置玩家变量(事件玩家, ram_block_damage, 0);
        设置玩家变量(事件玩家, hudText, 自定义字符串(""));
        //lbl_0:
    }
}

规则 ("[Ramattra]: block HUD") {
    事件 {
        持续 - 每名玩家;
        队伍2;
