{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Debug_GameTime == 真;
		游戏正在进行中 == 真;
		(当前游戏模式 == 游戏模式(攻击护送) || 当前游戏模式 == 游戏模式(攻防作战) || 当前游戏模式 == 游戏模式(运载目标)) == 真;
	}

	动作
	{
		设置比赛时间(120);
	}
}

规则("[Global][Debug]Game Time")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Debug_GameTime == 真;
		游戏正在进行中 == 真;
		当前游戏模式 == 游戏模式(占领要点);
	}

	动作
	{
		设置比赛时间(10);
	}
}

规则("[Player]Setup Heros")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.Heros = 空数组;
		修改全局变量(Heros, 添加至数组, 英雄(D.Va));
		修改全局变量(Heros, 添加至数组, 英雄(奥丽莎));
		修改全局变量(Heros, 添加至数组, 英雄(莱因哈特));
		修改全局变量(Heros, 添加至数组, 英雄(路霸));
		修改全局变量(Heros, 添加至数组, 英雄(温斯顿));
		修改全局变量(Heros, 添加至数组, 英雄(西格玛));
		修改全局变量(Heros, 添加至数组, 英雄(破坏球));
		修改全局变量(Heros, 添加至数组, 英雄(查莉娅));
		根据条件跳过(全局.Debug_UltimateGain != 0, 1);
		修改全局变量(Heros, 添加至数组, 英雄(半藏));
		修改全局变量(Heros, 添加至数组, 英雄(回声));
		禁用 修改全局变量(Heros, 添加至数组, 英雄(堡垒));
		修改全局变量(Heros, 添加至数组, 英雄(士兵：76));
		禁用 修改全局变量(Heros, 添加至数组, 英雄(托比昂));
		修改全局变量(Heros, 添加至数组, 英雄(末日铁拳));
		修改全局变量(Heros, 添加至数组, 英雄(死神));
