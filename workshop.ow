禁用 规则("【重生室】清除状态与效果")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		在重生室中(事件玩家) == 真;
	}

	动作
	{
		清除状态(事件玩家, 被入侵);
		清除状态(事件玩家, 点燃);
		清除状态(事件玩家, 击倒);
		清除状态(事件玩家, 沉睡);
		清除状态(事件玩家, 冻结);
		清除状态(事件玩家, 无法杀死);
		清除状态(事件玩家, 无敌);
		清除状态(事件玩家, 消散);
		清除状态(事件玩家, 定身);
		清除状态(事件玩家, 昏迷);
		设置移动速度(事件玩家, 100);
		等待(0.250, 当为“假”时中止);
		如条件为”真“则循环;
	}
}

规则("【阵亡】清除状态与效果")
{
