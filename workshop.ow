规则("[Player]Remove Player from Blacklist")
{
	事件
	{
		玩家加入比赛;
		队伍2;
		全部;
	}

	条件
	{
		禁用 数组包含(全局.N, 自定义字符串("{0}", 事件玩家)) == 真;
		(数组包含(全局.N, 自定义字符串("{0}", 事件玩家)) && 全局.Pure) == 真;
	}

	动作
	{
		移除玩家(事件玩家);
	}
}

规则("[Global][Debug]Auto Ultimate Gain")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.Debug_UltimateGain != 0;
		终极技能充能百分比(事件玩家) < 100;
	}

	动作
	{
		根据条件跳过(全局.Debug_UltimateGain != 1, 1);
		设置终极技能充能(事件玩家, 100);
		根据条件跳过(全局.Debug_UltimateGain != 2, 1);
		设置终极技能充能(所有玩家(队伍1), 100);
		根据条件跳过(全局.Debug_UltimateGain != 3, 1);
		设置终极技能充能(所有玩家(队伍2), 100);
		等待(0.250, 无视条件);
		如条件为“真”则循环;
	}
}

规则("[Global][Debug]Auto Cooldown")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.Debug_AbilitiesCooldown != 0;
		实体存在(事件玩家) == 真;
	}

	动作
	{
		根据条件跳过(全局.Debug_AbilitiesCooldown != 1, 4);
		设置技能冷却(事件玩家, 按钮(主要攻击模式), 0);
		设置技能冷却(事件玩家, 按钮(辅助攻击模式), 0);
		设置技能冷却(事件玩家, 按钮(技能1), 0);
		设置技能冷却(事件玩家, 按钮(技能2), 0);
		根据条件跳过(全局.Debug_AbilitiesCooldown != 2, 4);
		设置技能冷却(所有玩家(队伍1), 按钮(主要攻击模式), 0);
		设置技能冷却(所有玩家(队伍1), 按钮(辅助攻击模式), 0);
		设置技能冷却(所有玩家(队伍1), 按钮(技能1), 0);
		设置技能冷却(所有玩家(队伍1), 按钮(技能2), 0);
		根据条件跳过(全局.Debug_AbilitiesCooldown != 3, 4);
		设置技能冷却(所有玩家(队伍2), 按钮(主要攻击模式), 0);
		设置技能冷却(所有玩家(队伍2), 按钮(辅助攻击模式), 0);
		设置技能冷却(所有玩家(队伍2), 按钮(技能1), 0);
		设置技能冷却(所有玩家(队伍2), 按钮(技能2), 0);
		等待(0.180, 无视条件);
		如条件为“真”则循环;
	}
}

规则("[Global][Debug]Auto Cooldown")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.Debug_AbilitiesCooldown != 0;
		实体存在(事件玩家) == 真;
	}

	动作
	{
		根据条件跳过(全局.Debug_AbilitiesCooldown != 1, 6);
		根据条件跳过(所用英雄(事件玩家) != 英雄(布丽吉塔), 1);
		设置技能充能(事件玩家, 按钮(技能2), 3);
		根据条件跳过(所用英雄(事件玩家) != 英雄(秩序之光), 1);
		设置技能充能(事件玩家, 按钮(技能1), 3);
		根据条件跳过(所用英雄(事件玩家) != 英雄(狂鼠), 1);
		设置技能充能(事件玩家, 按钮(技能1), 2);
		根据条件跳过(全局.Debug_AbilitiesCooldown != 2, 6);
		根据条件跳过(所用英雄(事件玩家) != 英雄(布丽吉塔), 1);
		设置技能充能(所有玩家(队伍1), 按钮(技能2), 3);
		根据条件跳过(所用英雄(事件玩家) != 英雄(秩序之光), 1);
		设置技能充能(所有玩家(队伍1), 按钮(技能1), 3);
		根据条件跳过(所用英雄(事件玩家) != 英雄(狂鼠), 1);
		设置技能充能(所有玩家(队伍1), 按钮(技能2), 1);
		根据条件跳过(全局.Debug_AbilitiesCooldown != 3, 6);
		根据条件跳过(所用英雄(事件玩家) != 英雄(布丽吉塔), 1);
		设置技能充能(所有玩家(队伍2), 按钮(技能2), 3);
		根据条件跳过(所用英雄(事件玩家) != 英雄(秩序之光), 1);
		设置技能充能(所有玩家(队伍2), 按钮(技能1), 3);
		根据条件跳过(所用英雄(事件玩家) != 英雄(狂鼠), 1);
		设置技能充能(所有玩家(队伍2), 按钮(技能2), 1);
		等待(0.180, 无视条件);
		如条件为“真”则循环;
	}
}

禁用 规则("[Global][Debug]Ultimate Ammo")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.Debug_AbilitiesCooldown != 0;
		实体存在(事件玩家) == 真;
		(按钮被按下(事件玩家, 按钮(主要攻击模式)) || 按钮被按下(事件玩家, 按钮(辅助攻击模式))) == 假;
		数组包含(数组(英雄(D.Va), 英雄(半藏), 英雄(布丽吉塔), 英雄(莱因哈特), 英雄(西格玛)), 所用英雄(事件玩家)) == 假;
	}

	动作
	{
		根据条件跳过(所用英雄(事件玩家) != 英雄(莫伊拉), 1);
		设置技能资源(事件玩家, 按钮(主要攻击模式), 100);
		设置弹药(事件玩家, 0, 最大弹药量(事件玩家, 0));
		设置弹药(事件玩家, 1, 最大弹药量(事件玩家, 1));
		等待(0.250, 无视条件);
		如条件为“真”则循环;
	}
}

