规则("[D.Va] Changelog")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		D.Va;
	}

	条件
	{
		处于非初始状态(事件玩家) == 假;
		在重生室中(事件玩家) == 真;
	}

	动作
	{
		等待(0.16, 无视条件);
		创建HUD文本(事件玩家, 空, 空, 自定义字符串(" \r\n\r\n\r\n\n"), 左边, 0, 空, 空, 真, 可见和字符串, 始终不可见);
		事件玩家.ChangelogText1 = 上一个文本ID;
		创建HUD文本(事件玩家, 空, 自定义字符串(" \r\n\r\n\n 非重装 AI 拥有 25% 伤害减免\r\n 重装 AI 拥有最高 40% 伤害减免"), 自定义字符串(
			"\r\n●\"{0}\"\r\n*整体伤害量提高 25%\r\n*伤害减免 40%\r\n{1} 防御矩阵\r\n 持续时间由 3 秒增加至 4 秒\r\n 完全充能时间由 6 秒降低至 2.5 秒\n\n※※离开重生室隐藏", 所用英雄(事件玩家),
			技能图标字符串(所用英雄(事件玩家), 按钮(辅助攻击模式))), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
		事件玩家.ChangelogText2 = 上一个文本ID;
	}
}

