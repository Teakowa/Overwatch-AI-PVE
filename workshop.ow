        玩家造成最后一击;
        队伍2;
        艾什;
    }
    条件 {
        游戏正在进行中 == 真;
        存活(事件玩家) == 真;
        弹药(事件玩家, 0) < 最大弹药(事件玩家, 0);
    }
    动作 {
        设置弹药(事件玩家, 0, 最大弹药(事件玩家, 0));
    }
}

规则 ("[Ash] ammo add by Coach Gun") {
    事件 {
        持续 - 每名玩家;
        队伍2;
        艾什;
    }
    条件 {
        正在使用技能 1(事件玩家) == 真;
    }
    动作 {
        等待直到 (非(正在使用技能 1(事件玩家)), 0.55);
        设置弹药(事件玩家, 0, If-Then-Else(比较(加(弹药(事件玩家, 0), 5), >, 最大弹药(事件玩家, 0)), 最大弹药(事件玩家, 0), 加(弹药(事件玩家, 0), 5)));
    }
}

规则 ("[Ashe]: headshot damage") {
    事件 {
        玩家造成伤害;
        双方;
        艾什;
    }
    条件 {
        数组中的值(全局.HeadshotDamage, 1) > 2;
        事件暴击 == 真;
        事件技能 != 按钮(技能1);
        事件技能 != 按钮(技能2);
        事件技能 != 按钮(终极技能);
    }
    动作 {
        伤害(被攻击方, 攻击方, 取整(除(乘(事件伤害, 减(数组中的值(全局.HeadshotDamage, 1), 2)), 2), 上));
    }
}

