规则("[Reinhardt] Heal burn damage")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		所用英雄(事件玩家) == 英雄(莱因哈特);
		事件技能 != 按钮(主要攻击模式);
		事件技能 != 按钮(技能1);
		禁用 事件技能 != 按钮(技能2);
		禁用 事件技能 != 按钮(终极技能);
		事件技能 != 按钮(近身攻击);
		生命值(事件玩家) < 最大生命值(事件玩家);
		存活(事件玩家) == 真;
	}

	动作
	{
		治疗(事件玩家, 事件玩家, 事件伤害 * (最大生命值(事件玩家) / 最大生命值(被攻击方)));
	}
}

