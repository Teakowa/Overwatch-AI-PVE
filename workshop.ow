规则("[Bot]Generated at the beginning")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		游戏正在进行中 == 真;
	}

	动作
	{
		移除所有机器人;
		等待(0.500, 无视条件);
		禁用 根据条件跳过(数量(已过滤的数组(所有玩家(队伍1), 是否是机器人(当前数组元素))) < 3, 2);
		禁用 小字体信息(主机玩家, 自定义字符串("AI 数量超出限制"));
		禁用 中止;
		根据条件跳过(数组包含(全局.W, 当前地图) == 假, 2);
		根据条件跳过(英雄数量(英雄(黑百合), 队伍1) >= 1, 1);
		开始规则(CreateBotBasedOnMap_Widowmaker, 无动作);
		根据条件跳过(数组包含(全局.P, 当前地图) == 假, 2);
		根据条件跳过(英雄数量(英雄(法老之鹰), 队伍1) >= 1, 1);
		开始规则(CreateBotBasedOnMap_Pharah, 无动作);
		根据条件跳过(全局.TankBotTotal == 0, 1);
		开始规则(CreateTankBot, 无动作);
		根据条件跳过(全局.DamageBotTotal == 0, 1);
		开始规则(CreateDamageBot, 无动作);
		根据条件跳过(全局.SupportBotTotal == 0, 1);
		开始规则(CreateSupportBot, 无动作);
	}
}

规则("[Bot]Generate Widowmaker based on map")
{
	事件
	{
		子程序;
		CreateBotBasedOnMap_Widowmaker;
	}

	动作
	{
		生成机器人(英雄(黑百合), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(0, 0,
			0));
		禁用 全局.DamageBotTotal = 全局.DamageBotTotal - 1;
	}
}

