规则("Initialize global variables")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.Debug_Record = 地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("查看器录制"), 假, 0);
		全局.Debug_GameTime = 地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("即时开始"), 假, 2);
		全局.Debug_AbilitiesCooldown = 地图工坊设置组合(自定义字符串("Debug"), 自定义字符串("即时技能冷却"), 0, 数组(自定义字符串("关"), 自定义字符串("双方"), 自定义字符串("队伍1"), 自定义字符串(
			"队伍2")), 3);
		全局.Debug_UltimateGain = 地图工坊设置组合(自定义字符串("Debug"), 自定义字符串("即时终极技能充能"), 0, 数组(自定义字符串("关"), 自定义字符串("双方"), 自定义字符串("队伍1"), 自定义字符串(
			"队伍2")), 4);
		全局.ANTI_CRASH_ACTIVATE_PERCENT = 地图工坊设置整数(自定义字符串("Anti Crash"), 自定义字符串("激活阈值"), 200, 0, 250, 0);
		全局.ANTI_CRASH_HOLD_TIME = 地图工坊设置实数(自定义字符串("Anti Crash"), 自定义字符串("激活持续时间"), 8, 0, 20, 1);
		全局.ANTI_CRASH_DEACTIVATE_PERCENT = 地图工坊设置整数(自定义字符串("Anti Crash"), 自定义字符串("停用阈值"), 150, 0, 250, 2);
		全局.Pure = 地图工坊设置开关(自定义字符串("模式"), 自定义字符串("纯净模式"), 真, 10);
		"随机禁用英雄池中的4名英雄（1 重装 2输出 1辅助）"
		全局.Hero_BAN = 地图工坊设置开关(自定义字符串("模式"), 自定义字符串("英雄BAN池"), 假, 11);
		全局.Brigitte_RepairPacksHealing = 地图工坊设置整数(自定义字符串("英雄：布丽吉塔"), 自定义字符串("恢复包提供的瞬间治疗量"), 50, 0, 100, 30);
		全局.Brigitte_RepairPacksArmor = 地图工坊设置整数(自定义字符串("英雄：布丽吉塔"), 自定义字符串("恢复包提供的护甲"), 50, 0, 200, 31);
		全局.Brigitte_RepairPacksDuration = 地图工坊设置整数(自定义字符串("英雄：布丽吉塔"), 自定义字符串("恢复包提供的护甲留存时间"), 6, 1, 15, 32);
		全局.Brigitte_ChargesGained = 地图工坊设置整数(自定义字符串("英雄：布丽吉塔"), 自定义字符串("集结号令获得的额外恢复包"), 3, 0, 6, 33);
		全局.Brigitte_RallyArmor = 地图工坊设置整数(自定义字符串("英雄：布丽吉塔"), 自定义字符串("集结号令为自身提供的护甲"), 50, 0, 150, 34);
		全局.Mercy_ValkyrieDmgReduction = 地图工坊设置整数(自定义字符串("英雄：天使"), 自定义字符串("女武神伤害减免"), 30, 0, 100, 40);
		全局.Orisa_FortifyArmor = 地图工坊设置整数(自定义字符串("英雄：奥丽莎"), 自定义字符串("强固防御获得的临时护甲"), 100, 0, 150, 50);
		全局.Genji_Rank = 地图工坊设置整数(自定义字符串("英雄：源氏"), 自定义字符串("分数"), 1500, 500, 5000, 60);
		全局.WorkshopKnockupStrength = 地图工坊设置实数(自定义字符串("英雄：禅雅塔"), 自定义字符串("无影脚击退距离"), 13.500, 0, 100, 71);
		全局.OW1_DOOMFIST = 地图工坊设置开关(自定义字符串("英雄：末日铁拳"), 自定义字符串("Overwatch 1 版本（Tech Preview）"), 假, 80);
	}
