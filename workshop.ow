规则("[Anti Crash]: Activate anti crash")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		服务器负载 > 全局.ANTI_CRASH_ACTIVATE_PERCENT;
	}

	动作
	{
		等待(全局.ANTI_CRASH_HOLD_TIME, 当为“假”时中止);
		小字体信息(所有玩家(所有队伍), 自定义字符串("  服务器过载  "));
		设置慢动作(1);
		等待(0.500, 无视条件);
		等待直到 (服务器负载 < 全局.ANTI_CRASH_DEACTIVATE_PERCENT, 999999986991104.000);
		设置慢动作(100);
	}
}

规则("[Global]Setup Blacklist")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Pure == 真;
	}

	动作
	{
		全局.N = 空数组;
		修改全局变量(N, 添加至数组, 字符串分割(自定义字符串("HaoHao-Kojima-善良的米色法师-Symphony-暗無月-岛田卢西奥-yomi-Yang-鸭脖-無良粿子-OliveViper"), 自定义字符串("-")));
		修改全局变量(N, 添加至数组, 字符串分割(自定义字符串("Tazuki-猎豹铁拳-Yuki-LOVEYUKI-RustLich-Carbuncle-Azai-RustHawk-糕糕-ShiningFan"), 自定义字符串("-")));
		修改全局变量(N, 添加至数组, 字符串分割(自定义字符串("arisa-Makdou-蕭哥-Wesikiliye-momo-regacrusa-变诈-守望先锋给爷死-disma"), 自定义字符串("-")));
		修改全局变量(N, 添加至数组, 字符串分割(自定义字符串("我很可爱请给我钱-AaronLion-艾蕾灬伊修塔尔-大湿兄-旗木五五开-边哭边奶-上川浅音-飞哥-赏金猎人-苍穹之光-博企的因京"), 自定义字符串("-")));
		修改全局变量(N, 添加至数组, 字符串分割(自定义字符串("V0rteX17-YaHoo-Azunyan-bob-驴砸啊-XiaoYuanZzz-快快去送-GRAFE-Sophora-STARLIKE-你的噩梦-ADN13013"), 自定义字符串(
			"-")));
		修改全局变量(N, 添加至数组, 字符串分割(自定义字符串(
			"nanoahznehc-PinkSkyMHY-Hum0rousBoy-SEVN-Mikecarr-ChristinaQ-vEVYblKn-Mystery-亡靈犬-DJKanoeki-Nactual-Baby-mingzi-小6-喜多喜多酱"),
