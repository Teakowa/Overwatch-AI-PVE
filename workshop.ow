规则("[Bot]Goodbye World")
{
	事件
	{
		玩家造成最后一击;
		队伍1;
		全部;
	}

	条件
	{
		(存活(事件玩家) && 事件玩家.A[0]) == 真;
	}

	动作
	{
		交流(事件玩家, 问候);
		等待(2, 当为“真”时重新开始);
		交流(事件玩家, 再见);
	}
}

规则("[Bot]Generated at the beginning")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		(正在等待玩家 || 游戏正在进行中) == 真;
	}

	动作
	{
		调用子程序(Sub08);
		移除所有机器人;
		等待(0.850, 无视条件);
		根据条件跳过(英雄数量(英雄(路霸), 队伍1) == 1 || 英雄数量(英雄(查莉娅), 队伍1) == 1 || 英雄数量(英雄(安娜), 队伍1) == 1, 2);
		禁用 宣布比赛为平局;
		禁用 中止;
		根据条件跳过(全局.TankBotTotal == 0, 1);
		开始规则(CreateTankBot, 无动作);
		根据条件跳过(全局.DamageBotTotal == 0 || 全局.Tank == 3, 1);
		开始规则(CreateDamageBot, 无动作);
		根据条件跳过(全局.SupportBotTotal == 0 || 全局.TankBotTotal + 全局.DamageBotTotal >= 3, 1);
		开始规则(CreateSupportBot, 无动作);
	}
}

规则("[Bot]Generate Tank based on total")
{
	事件
	{
		子程序;
		CreateTankBot;
	}

	动作
	{
		生成机器人(数组随机取值(全局.Tank), 队伍1, 3, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(0,
			0, 0));
		修改全局变量(Tank, 根据值从数组中移除, 所用英雄(此栏位的玩家(3, 队伍1)));
		根据条件跳过(全局.TankBotTotal == 1, 5);
		生成机器人(数组随机取值(全局.Tank), 队伍1, 4, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(0,
			0, 0));
		修改全局变量(Tank, 根据值从数组中移除, 所用英雄(此栏位的玩家(4, 队伍1)));
		根据条件跳过(全局.TankBotTotal == 2, 2);
		生成机器人(数组随机取值(全局.Tank), 队伍1, 5, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(0,
			0, 0));
		修改全局变量(Tank, 根据值从数组中移除, 所用英雄(此栏位的玩家(5, 队伍1)));
	}
}

规则("[Bot]Generate Damage based on total")
{
	事件
	{
		子程序;
		CreateDamageBot;
	}

	动作
	{
		根据条件跳过(数组包含(全局.P, 当前地图) == 假, 3);
		根据条件跳过(英雄数量(英雄(法老之鹰), 队伍1) >= 1, 2);
		生成机器人(英雄(法老之鹰), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(0, 0,
			0));
		修改全局变量(Damage, 根据值从数组中移除, 英雄(法老之鹰));
		生成机器人(数组随机取值(全局.Damage), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)),
			矢量(0, 0, 0));
		根据条件跳过(!数组包含(全局.Damage, 所用英雄(此栏位的玩家(3, 队伍1))), 1);
		修改全局变量(Damage, 根据值从数组中移除, 所用英雄(此栏位的玩家(3, 队伍1)));
		根据条件跳过(全局.DamageBotTotal == 1, 7);
		生成机器人(数组随机取值(全局.Damage), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)),
			矢量(0, 0, 0));
		根据条件跳过(!数组包含(全局.Damage, 所用英雄(此栏位的玩家(4, 队伍1))), 1);
		修改全局变量(Damage, 根据值从数组中移除, 所用英雄(此栏位的玩家(4, 队伍1)));
		根据条件跳过(全局.DamageBotTotal == 2, 3);
		生成机器人(数组随机取值(全局.Damage), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)),
			矢量(0, 0, 0));
		根据条件跳过(!数组包含(全局.Damage, 所用英雄(此栏位的玩家(5, 队伍1))), 1);
		修改全局变量(Damage, 根据值从数组中移除, 所用英雄(此栏位的玩家(5, 队伍1)));
	}
}

规则("[Bot]Generate Support based on total")
{
	事件
	{
		子程序;
		CreateSupportBot;
	}

	动作
	{
		If(英雄数量(英雄(莱因哈特), 队伍1) >= 1 || 英雄数量(英雄(温斯顿), 队伍1) >= 1 || 英雄数量(英雄(D.Va), 队伍1) >= 1 || 假);
			生成机器人(英雄(卢西奥), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(0, 0,
				0));
			修改全局变量(Support, 根据值从数组中移除, 英雄(卢西奥));
		End;
		禁用 根据条件跳过(!数组包含(全局.Support, 英雄(天使)), 4);
		If(英雄数量(英雄(回声), 队伍1) >= 1 || 英雄数量(英雄(法老之鹰), 队伍1) >= 1 || 英雄数量(英雄(艾什), 队伍1) >= 1 || 假);
			生成机器人(英雄(天使), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(0, 0, 0));
			修改全局变量(Support, 根据值从数组中移除, 英雄(天使));
		End;
		生成机器人(数组随机取值(全局.Support), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)),
			矢量(0, 0, 0));
		修改全局变量(Support, 根据值从数组中移除, 所用英雄(此栏位的玩家(3, 队伍1)));
		修改全局变量(Support, 根据值从数组中移除, 所用英雄(此栏位的玩家(4, 队伍1)));
		根据条件跳过(全局.SupportBotTotal == 1, 6);
		生成机器人(数组随机取值(全局.Support), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)),
			矢量(0, 0, 0));
		修改全局变量(Support, 根据值从数组中移除, 所用英雄(此栏位的玩家(3, 队伍1)));
		修改全局变量(Support, 根据值从数组中移除, 所用英雄(此栏位的玩家(4, 队伍1)));
		根据条件跳过(全局.SupportBotTotal == 2, 3);
		生成机器人(数组随机取值(全局.Support), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)),
			矢量(0, 0, 0));
		修改全局变量(Support, 根据值从数组中移除, 所用英雄(此栏位的玩家(3, 队伍1)));
		修改全局变量(Support, 根据值从数组中移除, 所用英雄(此栏位的玩家(4, 队伍1)));
	}
}

