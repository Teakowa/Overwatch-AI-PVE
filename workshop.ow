        首个((事件玩家).reset_pvar) == 假;
        (事件玩家).ram_block_damage > 0;
    }
    动作 {
        "eventPlayer.ram_block_damage_hud = getLastCreatedText()"
        等待直到 (或(或(比较((事件玩家).ram_block_damage, ==, 0), 首个((事件玩家).reset_pvar)), 在重生室中(事件玩家)), 999999986991104);
        设置玩家变量(事件玩家, hudText, 自定义字符串(""));
    }
}

规则 ("[Orisa]Fortify ricochet damage") {
    事件 {
        玩家受到伤害;
        双方;
        奥丽莎;
    }
    条件 {
        或(正在使用技能 1(事件玩家), 正在使用终极技能(事件玩家)) == 真;
        具有状态(事件玩家, 被入侵) == 假;
    }
    动作 {
        伤害(攻击方, 事件玩家, 乘(除(数组中的值(全局.Orisa_Fortify, 1), 100), 事件伤害));
    }
}

规则 ("[Orisa]: stun when ult") {
    事件 {
        玩家造成击退;
        双方;
        奥丽莎;
    }
    条件 {
        事件技能 == 按钮(终极技能);
        (被攻击方).unaffected != 真;
    }
    动作 {
        设置状态(被攻击方, 攻击方, 击晕, 1.25);
    }
}

规则 ("[Orisa]: stun when ult") {
    事件 {
        玩家造成击退;
        双方;
        奥丽莎;
    }
    条件 {
        事件技能 == 按钮(辅助攻击模式);
        存活(被攻击方) == 真;
        (被攻击方).unaffected != 真;
    }
    动作 {
        等待(0.3, 当为“假”时中止);
        根据条件跳过(比较(数组中的值((被攻击方).zarya_buff, 1), !=, 空), 13);
        根据条件跳过(比较((被攻击方).orisa_buff, ==, 真), 12);
        设置玩家变量(被攻击方, orisa_buff, 真);
        If(比较(绝对值((被攻击方).mov_speed_buff), <, 数组中的值(全局.Orisa_Fortify, 2)));
            设置玩家变量(被攻击方, mov_speed_buff, 乘(-1, 数组中的值(全局.Orisa_Fortify, 2)));
            设置移动速度(被攻击方, 较小(较大(加(100, (被攻击方).mov_speed_buff), 20), 200));
        End;
        等待(2, 无视条件);
        根据条件跳过(比较((被攻击方).orisa_buff, !=, 真), 5);
        If(比较((被攻击方).mov_speed_buff, ==, 乘(-1, 数组中的值(全局.Orisa_Fortify, 2))));
            设置玩家变量(被攻击方, mov_speed_buff, 0);
            设置移动速度(被攻击方, 较小(较大(加(100, (被攻击方).mov_speed_buff), 20), 200));
        End;
        设置玩家变量(被攻击方, orisa_buff, 假);
        //lbl_0:
    }
}

