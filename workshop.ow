规则("[Bot]开始行走")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		(存活(事件玩家) && 事件玩家.A[0]) == 真;
	}

	动作
	{
		If(所用英雄(事件玩家) == 英雄(天使));
			禁用 停止定向阈值(事件玩家);
			禁用 根据条件跳过(存活(事件玩家.MercyTarget), 1);
			禁用 开始定向阈值(事件玩家, 方向(事件玩家, 事件玩家.A[3]), 1, 至地图, 替换现有阈值, 方向和幅度);
			禁用 根据条件跳过(!存活(事件玩家.MercyTarget), 1);
			开始定向阈值(事件玩家, 方向(事件玩家, 事件玩家.MercyTarget), 1, 至地图, 替换现有阈值, 方向和幅度);
			禁用 等待(0.500, 无视条件);
			禁用 如条件为”真“则循环;
		Else;
			停止定向阈值(事件玩家);
			根据条件跳过(!存活(事件玩家.F), 3);
			根据条件跳过(事件玩家.A[4] || 在目标点上(事件玩家), 1);
			开始定向阈值(事件玩家, 方向(事件玩家, 所选位置(事件玩家.F)), 1, 至地图, 替换现有阈值, 方向和幅度);
			根据条件跳过(事件玩家.A[4] == 假, 1);
			开始定向阈值(事件玩家, 方向(事件玩家, 事件玩家.A[3]), 1, 至地图, 替换现有阈值, 方向和幅度);
			等待(0.500, 无视条件);
			如条件为”真“则循环;
			停止定向阈值(事件玩家);
		End;
	}
}

