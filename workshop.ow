规则("[echo/init.opy]: Set Life for echo when duplicating a tank")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		回声;
	}

	条件
	{
		正在人格复制(事件玩家) == 真;
	}

	动作
	{
		事件玩家.hero_id_duplicated = 数组值的索引(全部英雄, 正在复制的英雄(事件玩家));
		等待(1, 无视条件);
		事件玩家.custom_hp_pvar[0] = 首个(全局.health_pool[事件玩家.hero_id_duplicated]);
		事件玩家.custom_hp_pvar[1] = 全局.health_pool[事件玩家.hero_id_duplicated][1];
		事件玩家.custom_hp_pvar[2] = 全局.health_pool[事件玩家.hero_id_duplicated][2];
		调用子程序(applyCustomHp);
		等待直到 (!正在人格复制(事件玩家), 15);
