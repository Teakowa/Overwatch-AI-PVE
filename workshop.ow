规则("[Bot]Echo Duplicate Attack Mode")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		回声;
	}

	条件
	{
		(存活(事件玩家) && 正在使用终极技能(事件玩家) && 事件玩家.A[0]) == 真;
	}

	动作
	{
		If(正在复制的英雄(事件玩家) == 英雄(黑百合));
			设置武器(事件玩家, 2);
		Else If(正在复制的英雄(事件玩家) == 英雄(天使));
			设置武器(事件玩家, 2);
		End;
	}
}

