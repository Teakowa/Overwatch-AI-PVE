规则 ("[Cassidy.opy]: Revert sniper damage falloff") {
    事件 {
        玩家造成伤害;
        双方;
        卡西迪;
    }
    条件 {
        事件技能 == 按钮(主要攻击模式);
        相距距离(眼睛位置(攻击方), 被攻击方) > 25;
    }
    动作 {
        设置玩家变量(事件玩家, scoped_shot_distance, 相距距离(眼睛位置(攻击方), 被攻击方));
        "原OW2衰减计算（25-35米 70%衰减）"
        设置玩家变量(事件玩家, ow2_scoped_damage_falloff_scalar, 加(减(1, 乘(除(减((事件玩家).scoped_shot_distance, 25), 10), 0.7)), 减(1, 除(减((事件玩家).scoped_shot_distance, 25), 10))));
        If(比较((事件玩家).ow2_scoped_damage_falloff_scalar, >, 1));
            设置玩家变量(事件玩家, ow2_scoped_damage_falloff_scalar, 1);
        Else If(比较((事件玩家).ow2_scoped_damage_falloff_scalar, <, 0.3));
            设置玩家变量(事件玩家, ow2_scoped_damage_falloff_scalar, 0.3);
        End;
        设置玩家变量(事件玩家, scoped_damage_base, 除(事件伤害, (事件玩家).ow2_scoped_damage_falloff_scalar));
        设置玩家变量(事件玩家, ow1_scoped_damage_falloff_scalar, 减(1, 乘(除(减((事件玩家).scoped_shot_distance, 25), 25), 0.3)));
        "Cap min/max scalar\nMax damage scalar"
        If(比较((事件玩家).ow1_scoped_damage_falloff_scalar, <, 0.7));
            设置玩家变量(事件玩家, ow1_scoped_damage_falloff_scalar, 0.7);
        End;
        If(比较((事件玩家).scoped_shot_distance, >, 50));
            设置玩家变量(事件玩家, ow1_scoped_damage_falloff_scalar, 0.7);
        End;
        设置玩家变量(事件玩家, expected_scoped_damage, 乘((事件玩家).scoped_damage_base, (事件玩家).ow1_scoped_damage_falloff_scalar));
        伤害(被攻击方, 攻击方, 取整(减((事件玩家).expected_scoped_damage, 事件伤害), 上));
    }
}

