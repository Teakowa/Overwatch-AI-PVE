//Strict optimizations enabled
规则 ("Copyright (c) 2019-2025 他又（aka Teakowa）") {
    事件 {
        持续 - 全局;
    }
    动作 {
        禁用查看器录制;
        设置全局变量(Collaborator, 数组(自定义字符串("他又"), 自定义字符串("别感冒"), 自定义字符串("步六孤"), 自定义字符串("Destiny"), 自定义字符串("smile")));
        设置全局变量(Mark, 自定义字符串(" \r\n\n 非重装 AI 减伤 25%\r\n 重装 AI 最高减伤 40%\r\n 完整更新日志 workshop.codes/3TP7F/update-log\r\n 企鹅聊天群：361913638\r\n 中途退、挂机永久BAN，不服的现在滚"));
        "Setup Anti Crash"
        设置全局变量(ANTI_CRASH_ACTIVATE_PERCENT, 地图工坊设置整数(自定义字符串("Anti Crash"), 自定义字符串("激活阈值"), 230, 0, 250, 0));
        设置全局变量(ANTI_CRASH_HOLD_TIME, 地图工坊设置实数(自定义字符串("Anti Crash"), 自定义字符串("激活持续时间"), 8, 0, 20, 1));
        设置全局变量(ANTI_CRASH_DEACTIVATE_PERCENT, 地图工坊设置整数(自定义字符串("Anti Crash"), 自定义字符串("停用阈值"), 180, 0, 250, 2));
    }
}

