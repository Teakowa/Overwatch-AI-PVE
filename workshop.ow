规则 ("[Zenyatta]: Transcendence") {
    事件 {
        持续 - 每名玩家;
        双方;
        禅雅塔;
    }
    条件 {
        正在使用终极技能(事件玩家) == 真;
    }
    动作 {
        If(比较(绝对值((事件玩家).mov_speed_buff), <, 25));
            设置玩家变量(事件玩家, mov_speed_buff, 25);
            调用子程序(applySignedMoveSpeed);
        End;
        等待(0.16, 无视条件);
        设置状态(事件玩家, 空, 相移, 6);
        设置造成治疗(事件玩家, 133.34);
        等待直到 (或(非(正在使用终极技能(事件玩家)), 死亡(事件玩家)), 6);
        If(存活(事件玩家));
            If(比较((事件玩家).mov_speed_buff, ==, 25));
                设置玩家变量(事件玩家, mov_speed_buff, 0);
                调用子程序(applySignedMoveSpeed);
            End;
        End;
        设置造成治疗(事件玩家, 100);
    }
}

