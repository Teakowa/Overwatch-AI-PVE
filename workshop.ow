规则 ("[Anti Crash]: Activate anti crash") {
    事件 {
        持续 - 全局;
    }
    条件 {
        服务器负载平均值 > 全局.ANTI_CRASH_ACTIVATE_PERCENT;
    }
    动作 {
        等待(全局.ANTI_CRASH_HOLD_TIME, 当为“假”时中止);
        小字体信息(所有玩家(所有队伍), 自定义字符串("  服务器过载  "));
        设置慢动作(1);
        等待(0.5, 无视条件);
        等待直到 (比较(服务器负载平均值, <, 全局.ANTI_CRASH_DEACTIVATE_PERCENT), 999999986991104);
        设置慢动作(100);
    }
}

规则 ("[Global]Setup Blacklist") {
    事件 {
        持续 - 全局;
    }
    动作 {
        设置全局变量(Blacklist, 空数组);
        等待(除(服务器负载平均值, 100), 无视条件);
        修改全局变量(Blacklist, 添加至数组, 字符串分割(自定义字符串("为这点事活着吗-她与春风皆过客-Eliake-李幽州-LETSGODUDE-嗣音-河神与樵夫的交易"), 自定义字符串("-")));
        修改全局变量(Blacklist, 添加至数组, 字符串分割(自定义字符串("小哲-比奇堡悍匪-蓝海-啊哈哈哈哈-EdwardJoe-EQUA-小余天天开心-梦想成为源氏糕手-口执剑只为伊人口-折耳-必深深李雪花大姨-乌有"), 自定义字符串("-")));
