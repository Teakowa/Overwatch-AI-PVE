	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		(当前比赛模式 == 比赛模式(运载目标) || 当前比赛模式 == 比赛模式(攻击护送)) == 真;
		(在视线内(事件玩家, 运载目标位置, 屏障不会阻挡视线) != 真 && 范围内玩家(事件玩家, 37.500, 队伍2, 表面) != 真 && 数量(所有目标点内玩家(队伍2)) == 0 && 正在使用终极技能(事件玩家) != 真) == 真;
		(存活(事件玩家) && 运载目标进度百分比 >= 5 && 相距距离(事件玩家, 运载目标位置) >= 5 && 相距距离(事件玩家, 运载目标位置) < 20) == 真;
	}

	动作
	{
		等待(2, 当为“假”时中止);
		传送(事件玩家, 运载目标位置 + 矢量(随机实数(0, 1.500), 1.500, 随机实数(0, 1.500)));
	}
}

规则("[Bot] ACC")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		(当前比赛模式 == 比赛模式(运载目标) || 当前比赛模式 == 比赛模式(攻击护送)) == 真;
		(在视线内(事件玩家, 运载目标位置, 屏障不会阻挡视线) && 存活(事件玩家) && 数量(所有目标点内玩家(队伍2)) >= 1 && 数量(所有目标点内玩家(队伍1)) < 3 && 运载目标进度百分比 >= 2.500 && 相距距离(事件玩家,
			运载目标位置) >= 2.500 && 相距距离(事件玩家, 运载目标位置) < 25) == 真;
		比赛时间 == 0;
	}

	动作
	{
		开始加速(事件玩家, 方向(事件玩家, 运载目标位置), 100, 3, 至地图, 方向，速率，及最大速度);
		等待(2, 无视条件);
		如条件为”真“则循环;
		停止加速(事件玩家);
	}
}

规则("[Bot] Quick Melee")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		(是否是机器人(事件玩家) && 已过滤的数组(范围内玩家(事件玩家, 4, 队伍2, 表面), 存活(当前数组元素) && 生命值(当前数组元素) < 50) == 真) == 真;
		(存活(事件玩家) && 事件玩家.A[0]) == 真;
		(相距距离(事件玩家, 首个(已排序的数组(已过滤的数组(所有存活玩家(对方队伍(所在队伍(事件玩家))), 在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线) && !具有状态(当前数组元素, 消散) && !具有状态(当前数组元素, 沉睡) && !(
			正在使用技能 1(当前数组元素) && 所用英雄(当前数组元素) == 英雄(麦克雷) && 相距距离(事件玩家, 当前数组元素) > 3)), 相距距离(事件玩家, 当前数组元素)))) <= 2.500) == 真;
	}

	动作
	{
		按下按键(事件玩家, 按钮(近身攻击));
		等待(1, 无视条件);
		如条件为”真“则循环;
	}
}

规则("[Echo] Duplicating setup")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		回声;
	}

	条件
	{
		(正在人格复制(事件玩家) && 终极技能充能百分比(事件玩家) == 100) == 真;
	}

	动作
	{
		等待(0.016, 无视条件);
		按下按键(已过滤的数组(事件玩家, 事件玩家.A[4] && 真 && 真 && 真), 按钮(终极技能));
		等待(1.600, 当为“真”时重新开始);
	}
}

规则("[Echo] Duplicating Brigitte set hp")
{
	事件
	{
		持续 - 每名玩家;
