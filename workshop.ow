规则 ("Changelog") {
    事件 {
        持续 - 每名玩家;
        队伍2;
        全部;
    }
    条件 {
        游戏正在进行中 == 假;
        在重生室中(事件玩家) == 真;
    }
    动作 {
        等待(0.16, 无视条件);
        调用子程序(changelogText);
        等待直到 (非(在重生室中(事件玩家)), 999999986991104);
        消除HUD文本((事件玩家).ChangelogText1);
        消除HUD文本((事件玩家).ChangelogText2);
    }
}

