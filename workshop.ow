        持续 - 每名玩家;
        双方;
        安娜;
    }
    条件 {
        终极技能充能百分比(事件玩家) == 100;
    }
    动作 {
        等待直到 (比较(终极技能充能百分比(事件玩家), ==, 0), 99999);
        设置玩家变量(事件玩家, nano_full_health, 已过滤的数组(距离准星最近的玩家(事件玩家, 所在队伍(事件玩家)), 比较(生命值(当前数组元素), >=, 最大生命值(当前数组元素))));
        伤害((事件玩家).nano_full_health, 空, 0.05);
        等待(0.216, 无视条件);
        治疗((事件玩家).nano_full_health, 空, 0.05);
        设置玩家变量(事件玩家, nano_full_health, 空);
    }
}

规则 ("Has Nano") {
    事件 {
        玩家受到治疗;
        双方;
        全部;
    }
    条件 {
        "This checks that the ability used to deal the healing is the ultimate."
        事件技能 == 按钮(终极技能);
        "This checks if the player who dealt the healing is Ana or an Echo duplicating an Ana."
        所用英雄(治疗者) == 英雄(安娜);
    }
    动作 {
        设置玩家变量(事件玩家, has_nano, 真);
        等待直到 (死亡(事件玩家), 8);
        设置玩家变量(事件玩家, has_nano, 假);
    }
}

规则 ("[Ana] Nano Boost Healing") {
    事件 {
        玩家造成治疗;
        双方;
        安娜;
    }
    条件 {
        事件技能 == 按钮(终极技能);
        所用英雄(治疗者) == 英雄(安娜);
    }
    动作 {
        治疗(受治疗者, 治疗者, 99999);
    }
}

规则 ("【布丽吉塔】恢复包提供护甲") {
    事件 {
        持续 - 每名玩家;
        双方;
        全部;
    }
    条件 {
        数组中的值(全局.Brigitte, 1) != 0;
        所用英雄(事件玩家) != 英雄(布丽吉塔);
        存活(事件玩家) == 真;
        (事件玩家).brig_repair_pack != 假;
    }
    动作 {
        设置玩家变量(事件玩家, brig_repair_pack, 假);
        根据条件跳过(比较((事件玩家).brig_repair_pack_id, ==, 空), 1);
        移除玩家的生命池((事件玩家).brig_repair_pack_id);
        //lbl_0:
        为玩家添加生命池(事件玩家, 护甲, 数组中的值(全局.Brigitte, 1), 假, 假);
        小字体信息(事件玩家, 自定义字符串("  {0} 获得来自 {1} 的护甲", 技能图标字符串(英雄(布丽吉塔), 按钮(技能2)), 所用英雄(数组中的值((事件玩家).reset_pvar, 1))));
        设置玩家变量(事件玩家, brig_repair_pack_id, 最后创建的生命池);
    }
}

规则 ("[Ana]: Sleep tanks for longer duration") {
