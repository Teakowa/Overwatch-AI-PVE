}

规则 ("[Sombra] TP to Support") {
    事件 {
        持续 - 每名玩家;
        队伍1;
        黑影;
    }
    条件 {
        正在使用技能 1(事件玩家) == 假;
        正在使用辅助武器(事件玩家) == 假;
        正在使用主要武器(事件玩家) == 假;
        技能冷却时间(事件玩家, 按钮(技能2)) != 0;
        存活(首个(数组中的值((事件玩家).reset_pvar, 9))) == 真;
        在重生室中(首个(数组中的值((事件玩家).reset_pvar, 9))) == 假;
        与(在目标点上(事件玩家), 在重生室中(事件玩家)) == 假;
        相距距离(事件玩家, 首个(数组中的值((事件玩家).reset_pvar, 9))) >= 5.5;
        相距距离(距离最近的玩家(事件玩家, 所在队伍(事件玩家)), 首个(数组中的值((事件玩家).reset_pvar, 9))) <= 30;
    }
    动作 {
        等待(2, 当为“假”时中止);
        传送(事件玩家, 最近的可行走位置(减(首个(数组中的值((事件玩家).reset_pvar, 9)), 地图矢量(矢量(0, 0, -7), 事件玩家, 旋转))));
        开始朝向(事件玩家, 向量(逐帧更新(眼睛位置(事件玩家)), 眼睛位置(首个(已排序的数组(已过滤的数组(所有存活玩家(对方队伍(所在队伍(事件玩家))), 在视线内(眼睛位置(事件玩家), 眼睛位置(当前数组元素), 屏障不会阻挡视线)), 相距距离(眼睛位置(事件玩家), 眼睛位置(当前数组元素)))))), 10000, 至地图, 方向及角速率);
        等待直到 (死亡(首个(数组中的值((数组中的值((事件玩家).reset_pvar, 4)).reset_pvar, 9))), 2);
        停止朝向(事件玩家);
        等待(3, 无视条件);
    }
}

