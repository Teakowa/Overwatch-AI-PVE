规则 ("[Ramattra] ult speed") {
    事件 {
        持续 - 每名玩家;
        双方;
        拉玛刹;
    }
    条件 {
        正在使用终极技能(事件玩家) == 真;
    }
    动作 {
        If(比较(绝对值((事件玩家).mov_speed_buff), <, 绝对值(数组中的值(全局.Ram_Annihilation, 3))));
            设置玩家变量(事件玩家, mov_speed_buff, 数组中的值(全局.Ram_Annihilation, 3));
            调用子程序(applySignedMoveSpeed);
        End;
        设置造成伤害(事件玩家, 加(100, 数组中的值(全局.Ram_Annihilation, 5)));
        设置受到伤害(事件玩家, 减(100, 数组中的值(全局.Ram_Annihilation, 4)));
        设置受到的击退(事件玩家, 30);
        等待直到 (或(非(正在使用终极技能(事件玩家)), 死亡(事件玩家)), 999999986991104);
        根据条件跳过(死亡(事件玩家), 4);
        If(比较((事件玩家).mov_speed_buff, ==, 数组中的值(全局.Ram_Annihilation, 3)));
            设置玩家变量(事件玩家, mov_speed_buff, 0);
            调用子程序(applySignedMoveSpeed);
        End;
        //lbl_0:
        设置受到伤害(事件玩家, 100);
        设置受到的击退(事件玩家, 100);
        设置造成伤害(事件玩家, 100);
        等待(0.16, 无视条件);
    }
}

