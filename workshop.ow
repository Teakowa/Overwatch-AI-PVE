        设置状态(被攻击方, 攻击方, 击倒, 4);
    }
}

规则 ("[JunkerQueen]: Commanding Shout taunt enemies") {
    事件 {
        持续 - 每名玩家;
        双方;
        渣客女王;
    }
    条件 {
        正在使用技能 1(事件玩家) == 真;
        数量(已过滤的数组(所有存活玩家(对方队伍(所在队伍(事件玩家))), 与(在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线), 比较(相距距离(事件玩家, 当前数组元素), <=, 15)))) > 0;
    }
    动作 {
        根据条件跳过(比较((事件玩家).junker_queen_buff, ==, 空), 1);
        移除玩家的生命池((事件玩家).junker_queen_buff);
        //lbl_0:
        设置玩家变量(已过滤的数组(所有存活玩家(对方队伍(所在队伍(事件玩家))), 与(与(在视线内(事件玩家, 当前数组元素, 屏障不会阻挡视线), 比较(相距距离(事件玩家, 当前数组元素), <=, 15)), 比较((当前数组元素).unaffected, !=, 真))), taunt, 真);
        等待(0.096, 无视条件);
        为玩家添加生命池(事件玩家, 生命值, 乘(500, 数量(已过滤的数组(所有存活玩家(对方队伍(所在队伍(事件玩家))), 比较((当前数组元素).taunt, ==, 真)))), 假, 假);
        设置玩家变量(事件玩家, junker_queen_buff, 最后创建的生命池);
        等待(6, 无视条件);
        移除玩家的生命池((事件玩家).junker_queen_buff);
    }
}

