规则("[Bot]Generate at the beginning")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		游戏正在进行中 == 真;
	}

	动作
	{
		根据条件跳过(数量(已过滤的数组(所有玩家(队伍1), 是否是机器人(当前数组元素))) < 3, 2);
		小字体信息(主机玩家, 自定义字符串("AI 数量超出限制"));
		中止;
