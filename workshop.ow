规则 ("[Player]Remove Player from Blacklist") {
    事件 {
        玩家加入比赛;
        队伍2;
        全部;
    }
    条件 {
        数组包含(全局.Blacklist, 自定义字符串("{0}", 事件玩家)) == 真;
    }
    动作 {
        移除玩家(事件玩家);
    }
}

规则 ("[Player]Remove Player from Blacklist") {
    事件 {
        玩家离开比赛;
        队伍2;
        全部;
    }
    条件 {
        游戏正在进行中 == 真;
    }
    动作 {
        小字体信息(主机玩家, 自定义字符串("  {0}", 事件玩家));
        小字体信息(主机玩家, 自定义字符串("  {0}", 事件玩家));
        小字体信息(主机玩家, 自定义字符串("  {0}", 事件玩家));
    }
}

规则 ("[Player]Hero BAN") {
    事件 {
        持续 - 全局;
    }
    条件 {
        全局.Hero_BAN == 真;
    }
    动作 {
        根据条件跳过(非(数组包含(数组(地图(伊利奥斯), 地图(尼泊尔), 地图(漓江塔), 地图(釜山), 地图(绿洲城), 地图(巴黎), 地图(66号公路)), 当前地图)), 1);
        修改全局变量(Heros, 根据值从数组中移除, 英雄(路霸));
        //lbl_0:
        根据条件跳过(数组包含(数组(地图(伊利奥斯), 地图(尼泊尔), 地图(漓江塔), 地图(釜山), 地图(绿洲城), 地图(巴黎), 地图(66号公路)), 当前地图), 1);
        修改全局变量(Heros, 根据值从数组中移除, 数组随机取值(所有重装英雄));
        //lbl_1:
        修改全局变量(Heros, 根据值从数组中移除, 数组随机取值(所有输出英雄));
        修改全局变量(Heros, 根据值从数组中移除, 数组随机取值(所有输出英雄));
        根据条件跳过(非(数组包含(数组(地图(伊利奥斯), 地图(尼泊尔), 地图(漓江塔), 地图(绿洲城), 地图(釜山)), 当前地图)), 1);
        修改全局变量(Heros, 根据值从数组中移除, 英雄(卢西奥));
        //lbl_2:
        根据条件跳过(数组包含(数组(地图(伊利奥斯), 地图(尼泊尔), 地图(漓江塔), 地图(绿洲城), 地图(釜山)), 当前地图), 1);
        修改全局变量(Heros, 根据值从数组中移除, 数组随机取值(所有支援英雄));
        //lbl_3:
    }
}

规则 ("[Player]: Override allowed heroes list when player joins lobby") {
    事件 {
        玩家加入比赛;
        队伍2;
        全部;
    }
    动作 {
        If(比较(自定义字符串("{0}", 事件玩家), ==, 自定义字符串("他又")));
            设置玩家可选的英雄(事件玩家, 全部英雄);
        Else If(数组包含(全局.Collaborator, 自定义字符串("{0}", 事件玩家)));
            设置玩家可选的英雄(事件玩家, 添加至数组(全局.Heros, 数组(英雄(天使), 英雄(狂鼠), 英雄(托比昂))));
        Else;
            设置玩家可选的英雄(事件玩家, 全局.Heros);
        End;
        等待(0.16, 无视条件);
        设置玩家变量(事件玩家, hudText, 自定义字符串(""));
    }
}

规则 ("[Player]: hudText init") {
