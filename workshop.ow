	}

	条件
	{
		禁用 正在使用终极技能(事件玩家) == 真;
	}

	动作
	{
		禁用 治疗(事件玩家, 无, 50);
		开始持续治疗(事件玩家, 事件玩家, 2, 25);
		等待(2, 无视条件);
	}
}

