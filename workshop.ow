    事件 {
        持续 - 每名玩家;
        队伍2;
        全部;
    }
    动作 {
        设置最大复生时间(事件玩家, 10);
    }
}

规则 ("[utilities/reset]: reset when died") {
    事件 {
        玩家阵亡;
        双方;
        全部;
    }
    动作 {
        等待(除(服务器负载平均值, 100), 无视条件);
        设置玩家变量(事件玩家, hudText, 自定义字符串(""));
        设置玩家变量(事件玩家, has_nano, 假);
        在索引处设置玩家变量(事件玩家, zarya_buff, 0, 真);
        在索引处设置玩家变量(事件玩家, zarya_buff, 1, 空);
        设置玩家变量(事件玩家, ram_block_damage, 0);
        设置玩家变量(事件玩家, sigma_hyperspheres, 0);
        设置玩家变量(事件玩家, doom_buff, 0);
        调用子程序(resetStats);
        调用子程序(resetStatuses);
        调用子程序(resetFrenemies);
    }
}

规则 ("[utilities/move_speed.opy]: applySignedMoveSpeed()") {
    事件 {
        子程序;
        applySignedMoveSpeed;
    }
    动作 {
        设置移动速度(事件玩家, 较小(较大(加(100, (事件玩家).mov_speed_buff), 20), 200));
    }
}

规则 ("[utilities/move_speed.opy]: clearMoveSpeedDebuffs()") {
    事件 {
        子程序;
        clearMoveSpeedDebuffs;
    }
    动作 {
        在索引处设置玩家变量(事件玩家, brigitte_buff, 0, 假);
        设置玩家变量(事件玩家, orisa_buff, 假);
        在索引处设置玩家变量(事件玩家, wuyang_buff, 3, 假);
        在索引处设置玩家变量(事件玩家, wuyang_buff, 4, 假);
        设置玩家变量(事件玩家, mov_speed_penalty, 0);
        设置玩家变量(事件玩家, mov_speed_buff, 0);
        调用子程序(applySignedMoveSpeed);
    }
}

规则 ("[reset.opy]: Reinitialize hero on new round") {
    事件 {
        持续 - 每名玩家;
        双方;
        全部;
    }
    条件 {
        处于回合之间 == 真;
        所用英雄(事件玩家) != 英雄(黑影);
    }
    动作 {
        等待直到 (非(处于回合之间), 999999986991104);
        等待(1, 无视条件);
        调用子程序(resetHero);
        在索引处设置玩家变量(事件玩家, reset_pvar, 0, 真);
        记入查看器(自定义字符串("called init after new round"));
    }
}

规则 ("[utilities/hero_setup.opy]: Reset and initialize hero on hero switch") {
    事件 {
        持续 - 每名玩家;
        双方;
        全部;
    }
    条件 {
        首个((事件玩家).reset_pvar) != 假;
    }
    动作 {
        "wait(10 * TICK_DURATION)"
        消除HUD文本((事件玩家).ChangelogText1);
        消除HUD文本((事件玩家).ChangelogText2);
        调用子程序(resetHero);
        记入查看器(自定义字符串("called reset hero"));
    }
}

禁用 规则 ("[utilities/overhealth]: Decay Overhealth") {
    事件 {
        持续 - 每名玩家;
        双方;
        全部;
    }
    条件 {
        (事件玩家).overhealth_decay == 真;
        减(减(减(最大生命值(事件玩家), 类型的最大生命值(事件玩家, 生命值)), 类型的最大生命值(事件玩家, 护甲)), 类型的最大生命值(事件玩家, 护盾)) > 0;
    }
    动作 {
        等待(5, 当为“真”时重新开始);
        调用子程序(storeOverhealth);
        "While has OH"
        While(比较(减(减(减(最大生命值(事件玩家), 类型的最大生命值(事件玩家, 生命值)), 类型的最大生命值(事件玩家, 护甲)), 类型的最大生命值(事件玩家, 护盾)), >, 0));
            根据条件循环(比较(减(减(减(最大生命值(事件玩家), 类型的最大生命值(事件玩家, 生命值)), 类型的最大生命值(事件玩家, 护甲)), 类型的最大生命值(事件玩家, 护盾)), >, 首个((事件玩家).storedOverhealth)));
            "If not full HP, replace current OH with current OH - 1"
            If(比较(生命值(事件玩家), <, 最大生命值(事件玩家)));
                在索引处设置玩家变量(事件玩家, storedOverhealth, 1, 减(生命值(事件玩家), 首个((事件玩家).storedOverhealth)));
                While(比较(生命值(事件玩家), >, 数组中的值((事件玩家).storedOverhealth, 1)));
                    设置玩家生命值(事件玩家, 数组中的值((事件玩家).storedOverhealth, 1));
                End;
                在索引处修改玩家变量(事件玩家, storedOverhealth, 0, 减, 1);
                根据条件中止(比较(首个((事件玩家).storedOverhealth), <, 1));
                为玩家添加生命池(事件玩家, 生命值, 首个((事件玩家).storedOverhealth), 假, 假);
            Else;
                设置玩家生命值(事件玩家, 减(生命值(事件玩家), 1));
                调用子程序(storeOverhealth);
            End;
            等待(0.12, 无视条件);
        End;
    }
}

规则 ("[Zenyatta] Sub Knockback") {
    事件 {
        子程序;
        Knockback;
    }
    动作 {
        等待(0.016, 无视条件);
        施加推力(事件玩家, (事件玩家).KnockbackDirection, 全局.Zen_KnockupStrength, 至地图, 取消相反运动);
        施加推力(事件玩家, 上, 乘(全局.Zen_KnockupStrength, 0.3), 至地图, 取消相反运动);
    }
}

规则 ("[utilities/custom_hp.opy]: applyCustomHp()") {
    事件 {
        子程序;
        applyCustomHp;
    }
    动作 {
        根据条件中止(与(与(比较(类型的最大生命值(事件玩家, 生命值), ==, 首个((事件玩家).custom_hp_pvar)), 比较(类型的最大生命值(事件玩家, 护甲), ==, 数组中的值((事件玩家).custom_hp_pvar, 1))), 比较(类型的最大生命值(事件玩家, 护盾), ==, 数组中的值((事件玩家).custom_hp_pvar, 2))));
        "Find minimum hp scalar value that ensures\nthe scaled health/armor/shields is less or equal to\nthe desired custom health/armor/shield value"
        在索引处设置玩家变量(事件玩家, custom_hp_pvar, 6, 较小(较小(If-Then-Else(比较(数组中的值((事件玩家).custom_hp_pvar, 3), >, 0), 除(首个((事件玩家).custom_hp_pvar), 数组中的值((事件玩家).custom_hp_pvar, 3)), 999999995904), If-Then-Else(比较(数组中的值((事件玩家).custom_hp_pvar, 4), >, 0), 除(数组中的值((事件玩家).custom_hp_pvar, 1), 数组中的值((事件玩家).custom_hp_pvar, 4)), 999999995904)), If-Then-Else(比较(数组中的值((事件玩家).custom_hp_pvar, 5), >, 0), 除(数组中的值((事件玩家).custom_hp_pvar, 2), 数组中的值((事件玩家).custom_hp_pvar, 5)), 999999995904)));
        设置最大生命值(事件玩家, 乘(100, 数组中的值((事件玩家).custom_hp_pvar, 6)));
        等待直到 (比较(最大生命值(事件玩家), !=, 加(加(数组中的值((事件玩家).custom_hp_pvar, 3), 数组中的值((事件玩家).custom_hp_pvar, 4)), 数组中的值((事件玩家).custom_hp_pvar, 5))), 1);
        If(比较(减(首个((事件玩家).custom_hp_pvar), 类型的最大生命值(事件玩家, 生命值)), >=, 1));
            为玩家添加生命池(事件玩家, 生命值, 减(首个((事件玩家).custom_hp_pvar), 类型的最大生命值(事件玩家, 生命值)), 真, 假);
        End;
        If(比较(减(数组中的值((事件玩家).custom_hp_pvar, 1), 类型的最大生命值(事件玩家, 护甲)), >=, 1));
            为玩家添加生命池(事件玩家, 护甲, 减(数组中的值((事件玩家).custom_hp_pvar, 1), 类型的最大生命值(事件玩家, 护甲)), 真, 假);
        End;
        If(比较(减(数组中的值((事件玩家).custom_hp_pvar, 2), 类型的最大生命值(事件玩家, 护盾)), >=, 1));
            为玩家添加生命池(事件玩家, 护盾, 减(数组中的值((事件玩家).custom_hp_pvar, 2), 类型的最大生命值(事件玩家, 护盾)), 真, 假);
        End;
    }
}

规则 ("[utilities/custom_hp.opy]: clearCustomHp()") {
    事件 {
        子程序;
        clearCustomHp;
    }
    动作 {
        在索引处设置玩家变量(事件玩家, reset_pvar, 8, 假);
        移除玩家的所有生命值(事件玩家);
        等待(0.016, 无视条件);
        设置最大生命值(事件玩家, 100);
        等待(0.016, 无视条件);
        在索引处设置玩家变量(事件玩家, custom_hp_pvar, 0, 0);
        在索引处设置玩家变量(事件玩家, custom_hp_pvar, 1, 0);
        在索引处设置玩家变量(事件玩家, custom_hp_pvar, 2, 0);
        在索引处设置玩家变量(事件玩家, custom_hp_pvar, 3, 类型的最大生命值(事件玩家, 生命值));
        在索引处设置玩家变量(事件玩家, custom_hp_pvar, 4, 类型的最大生命值(事件玩家, 护甲));
        在索引处设置玩家变量(事件玩家, custom_hp_pvar, 5, 类型的最大生命值(事件玩家, 护盾));
        在索引处设置玩家变量(事件玩家, custom_hp_pvar, 6, 1);
        在索引处设置玩家变量(事件玩家, reset_pvar, 8, 真);
    }
}

