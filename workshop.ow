	条件
	{
		处于回合之间 == 真;
		所用英雄(事件玩家) != 英雄(黑影);
	}

	动作
	{
		等待直到 (!处于回合之间, 999999986991104.000);
		等待(1, 无视条件);
		调用子程序(resetHero);
		事件玩家.reset_pvar[0] = 真;
		记入查看器(自定义字符串("called init after new round"));
	}
}

