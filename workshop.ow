规则("Workshop Setting")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.Debug_Record = 地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("查看器录制"), 假, 0);
		全局.Debug_UltimateGain = 地图工坊设置组合(自定义字符串("Debug"), 自定义字符串("即时终极技能充能"), 0, 数组(自定义字符串("关"), 自定义字符串("双方"), 自定义字符串("队伍1"), 自定义字符串(
			"队伍2")), 2);
		全局.Debug_AbilitiesCooldown = 地图工坊设置组合(自定义字符串("Debug"), 自定义字符串("即时技能冷却"), 0, 数组(自定义字符串("关"), 自定义字符串("双方"), 自定义字符串("队伍1"), 自定义字符串(
			"队伍2")), 3);
		全局.Debug_GameTime = 地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("即时开始"), 假, 3);
		全局.Pure = 地图工坊设置开关(自定义字符串("模式"), 自定义字符串("纯净模式"), 真, 0);
		全局.Hero_BAN = 地图工坊设置开关(自定义字符串("模式"), 自定义字符串("英雄BAN池"), 假, 1);
		全局.Tank_RepelResistance = 地图工坊设置整数(自定义字符串("模式"), 自定义字符串("重装英雄受到的击退效果比例"), 100, 10, 100, 1);
		全局.TankBotTotal = 地图工坊设置整数(自定义字符串("机器人职责"), 自定义字符串("重装"), 0, 0, 3, 0);
		全局.DamageBotTotal = 地图工坊设置整数(自定义字符串("机器人职责"), 自定义字符串("输出"), 2, 0, 3, 1);
		全局.SupportBotTotal = 地图工坊设置整数(自定义字符串("机器人职责"), 自定义字符串("支援"), 1, 0, 3, 2);
		全局.NearDeath_MovingSpeed = 地图工坊设置整数(自定义字符串("游戏设置"), 自定义字符串("濒死移动速度"), 75, 50, 100, 0);
		全局.Ana_NanoBoostProvideUltCharge = 地图工坊设置整数(自定义字符串("安娜"), 自定义字符串("纳米激素提供的终极技能充能"), 25, 0, 50, 0);
		全局.Brigitte_RepairPacksHealing = 地图工坊设置整数(自定义字符串("布丽吉塔"), 自定义字符串("恢复包提供的瞬间治疗量"), 50, 0, 100, 0);
		全局.Brigitte_RepairPacksArmor = 地图工坊设置整数(自定义字符串("布丽吉塔"), 自定义字符串("恢复包提供的护甲"), 50, 0, 200, 1);
		全局.Brigitte_ChargesGained = 地图工坊设置整数(自定义字符串("布丽吉塔"), 自定义字符串("集结号令获得的额外恢复包"), 3, 0, 6, 2);
		全局.Brigitte_RallyArmor = 地图工坊设置整数(自定义字符串("布丽吉塔"), 自定义字符串("集结号令为自身提供的护甲"), 50, 0, 150, 3);
		全局.Mercy_ValkyrieDmgReduction = 地图工坊设置整数(自定义字符串("天使"), 自定义字符串("女武神受到伤害比率"), 50, 10, 100, 0);
		全局.Orisa_FortifyArmor = 地图工坊设置整数(自定义字符串("奥丽莎"), 自定义字符串("强固防御获得的临时护甲"), 100, 0, 150, 0);
		全局.Sombra_HackDeductUltCharge = 地图工坊设置整数(自定义字符串("黑影"), 自定义字符串("黑客入侵偷取终极技能充能能量"), 5, 0, 25, 0);
		全局.Genji_Rank = 地图工坊设置整数(自定义字符串("源氏"), 自定义字符串("分数"), 1500, 500, 5000, 0);
		全局.WorkshopLookDownOnly = 地图工坊设置开关(自定义字符串("禅雅塔"), 自定义字符串("无影脚仅在地面有效"), 假, 0);
		全局.WorkshopKnockupStrength = 地图工坊设置实数(自定义字符串("禅雅塔"), 自定义字符串("无影脚击退距离"), 13.500, 0, 100, 1);
	}
}

规则("[Global]Disable Record")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Debug_Record == 假;
	}

	动作
	{
		禁用查看器录制;
	}
}

禁用 规则("[Global] Kick afk player")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		游戏正在进行中 == 真;
		存活(事件玩家) == 真;
		已重生(事件玩家) != 真;
	}

	动作
	{
		等待(30, 当为“假”时中止);
		移除玩家(事件玩家);
	}
}

