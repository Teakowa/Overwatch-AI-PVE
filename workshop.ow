规则("[doomfist/uppercut.opy]: Detect uppercut victims")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.OW1_DOOMFIST == 真;
		事件玩家.reset_pvar[5].is_using_uppercut != 假;
		"Victim within uppercut hitbox range"
		相距距离(事件玩家.reset_pvar[5], 事件玩家) <= 5;
		"Victim in los of doomfist"
		在视线内(事件玩家.reset_pvar[5], 事件玩家, 屏障不会阻挡视线) == 真;
		"Victim in front of doomfist"
		矢量间夹角(地图矢量(前, 事件玩家.reset_pvar[5], 旋转), 方向(事件玩家.reset_pvar[5], 事件玩家)) <= 45;
		"attacker alive"
		存活(事件玩家.reset_pvar[5]) == 真;
		"victim alive"
		存活(事件玩家) == 真;
		(所用英雄(事件玩家) == 英雄(奥丽莎) && (正在使用技能 1(事件玩家) || 正在使用终极技能(事件玩家))) == 假;
		(所用英雄(事件玩家) == 英雄(毛加) && 正在使用技能 1(事件玩家)) == 假;
	}

	动作
	{
		事件玩家.is_hit_by_uppercut = 真;
		等待(1, 无视条件);
	}
}

规则("[doomfist/uppercut.opy]: Uppercut victim movement physics")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.OW1_DOOMFIST == 真;
		事件玩家.is_hit_by_uppercut == 真;
	}

	动作
	{
		"Lose movement control"
		开始限制阈值(事件玩家, 0, 0, 0, 0, 0, 0);
		施加推力(事件玩家, 上, 13.500, 至玩家, 取消相反运动XYZ);
		施加推力(事件玩家, 地图矢量(前, 事件玩家.reset_pvar[5], 旋转), 8.500, 至地图, 取消相反运动XYZ);
		等待(1.00, 无视条件);
		"Regain movement control"
		停止限制阈值(事件玩家);
		事件玩家.is_hit_by_uppercut = 假;
	}
}

