规则("Workshop Setting")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.Debug_Record = 地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("查看器录制"), 假, 0);
		全局.Debug_UltimateGain = 地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("即时终极技能充能"), 假, 1);
		全局.Debug_GameTime = 地图工坊设置开关(自定义字符串("Debug"), 自定义字符串("即时开始"), 假, 2);
		全局.TankBotTotal = 地图工坊设置整数(自定义字符串("机器人职责"), 自定义字符串("重装"), 0, 0, 3, 0);
		全局.DamageBotTotal = 地图工坊设置整数(自定义字符串("机器人职责"), 自定义字符串("输出"), 2, 0, 3, 1);
		全局.SupportBotTotal = 地图工坊设置整数(自定义字符串("机器人职责"), 自定义字符串("支援"), 1, 0, 3, 2);
		全局.NearDeath_MovingSpeed = 地图工坊设置整数(自定义字符串("游戏设置"), 自定义字符串("濒死移动速度"), 75, 50, 100, 0);
		全局.Ana_NanoBoostProvideUltCharge = 地图工坊设置整数(自定义字符串("安娜"), 自定义字符串("纳米激素提供的终极技能充能"), 25, 0, 50, 0);
		全局.Brigitte_RepairPacksHealing = 地图工坊设置整数(自定义字符串("布丽吉塔"), 自定义字符串("恢复包提供的瞬间治疗量"), 50, 0, 100, 0);
		全局.Brigitte_RepairPacksArmor = 地图工坊设置整数(自定义字符串("布丽吉塔"), 自定义字符串("恢复包提供的护甲值 *10"), 5, 0, 15, 1) * 10;
		全局.Brigitte_ChargesGained = 地图工坊设置整数(自定义字符串("布丽吉塔"), 自定义字符串("集结号令获得的额外恢复包"), 3, 0, 6, 2);
		全局.Brigitte_RallyArmor = 地图工坊设置整数(自定义字符串("布丽吉塔"), 自定义字符串("集结号令为自身提供的护甲 *10"), 5, 0, 10, 3) * 10;
		全局.Mercy_ValkyrieDmgReduction = 地图工坊设置整数(自定义字符串("天使"), 自定义字符串("女武神受到伤害比率"), 50, 10, 90, 0);
		全局.Orisa_FortifyArmor = 地图工坊设置整数(自定义字符串("奥丽莎"), 自定义字符串("强固防御获得的临时护甲 *10"), 10, 0, 15, 0) * 10;
		全局.Sombra_HackDeductUltCharge = 地图工坊设置整数(自定义字符串("黑影"), 自定义字符串("黑客入侵偷取终极技能充能能量"), 5, 0, 25, 0);
		全局.Genji_Rank = 地图工坊设置整数(自定义字符串("源氏"), 自定义字符串("分数"), 1500, 500, 5000, 0);
	}
}

规则("[Global]Disable Record")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Debug_Record == 假;
	}

	动作
	{
		禁用查看器录制;
	}
}

规则("[Global][Debug]Auto Ultimate Gain")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.Debug_UltimateGain == 真;
		终极技能充能百分比(事件玩家) < 100;
	}

	动作
	{
		设置终极技能充能(事件玩家, 100);
		等待(0.250, 无视条件);
		如条件为”真“则循环;
	}
}

规则("[Global][Debug]Game Time")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Debug_GameTime == 真;
		正在集结英雄 == 真;
	}

	动作
	{
		设置比赛时间(5);
	}
}

规则("[Global][Debug]Game Time")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Debug_GameTime == 真;
		正在设置 == 真;
	}

	动作
	{
		设置比赛时间(5);
	}
}

规则("[Global]Robot heroes array")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.Mechanical = 空数组;
		修改全局变量(Mechanical, 添加至数组, 英雄(回声));
		修改全局变量(Mechanical, 添加至数组, 英雄(奥丽莎));
		修改全局变量(Mechanical, 添加至数组, 英雄(禅雅塔));
		修改全局变量(Mechanical, 添加至数组, 英雄(堡垒));
	}
}

规则("[Global]Array of heroes affected by disarm")
{
	事件
	{
		持续 - 全局;
	}

	动作
	{
		全局.Disarm = 空数组;
