规则("[winston/primal.opy]: Fix primal rage hp")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		温斯顿;
	}

	条件
	{
		正在使用终极技能(事件玩家) == 真;
	}

	动作
	{
		事件玩家.custom_hp_pvar[0] = 850;
		事件玩家.custom_hp_pvar[1] = 150;
		事件玩家.custom_hp_pvar[2] = 0;
		调用子程序(applyCustomHp);
		等待直到 (!正在使用终极技能(事件玩家), 999999986991104.000);
		"Recreate primal exit hp logic"
		事件玩家.primal_pvar[0] = 类型的生命值(事件玩家, 生命值);
		事件玩家.primal_pvar[1] = 类型的生命值(事件玩家, 护甲);
		事件玩家.custom_hp_pvar[0] = 350;
		事件玩家.custom_hp_pvar[1] = 150;
		事件玩家.custom_hp_pvar[2] = 0;
		调用子程序(applyCustomHp);
		伤害(事件玩家, 空, (150 - 事件玩家.primal_pvar[1]) / 0.700);
		伤害(事件玩家, 空, 350 - 首个(事件玩家.primal_pvar));
	}
}

