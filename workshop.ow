		消除所有HUD文本;
	}
}

规则("[debug.opy]: global debug (Top Left)")
{
	事件
	{
		持续 - 全局;
	}

	条件
	{
		全局.Debug_Record == 真;
	}

	动作
	{
		创建HUD文本(所有玩家(所有队伍), 自定义字符串("Global"), 空, 空, 左边, 0, 颜色(白色), 空, 空, 可见和字符串, 默认可见度);
		创建HUD文本(所有玩家(所有队伍), 空, 自定义字符串("Server Load: {0}%", 服务器负载), 空, 左边, 1, 空, 颜色(白色), 空, 可见和字符串, 默认可见度);
		创建HUD文本(所有玩家(所有队伍), 空, 自定义字符串("Server Load Average: {0}%", 服务器负载平均值), 空, 左边, 1, 空, 颜色(白色), 空, 可见和字符串, 默认可见度);
		创建HUD文本(所有玩家(所有队伍), 空, 自定义字符串("Server Load Peak: {0}%", 服务器负载峰值), 空, 左边, 1, 空, 颜色(白色), 空, 可见和字符串, 默认可见度);
		创建HUD文本(所有玩家(所有队伍), 空, 自定义字符串("isInSetup: {0}", 正在设置), 空, 左边, 1, 空, 颜色(白色), 空, 可见和字符串, 默认可见度);
	}
}

规则("[debug.opy]: player debug (Top Right)")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
