规则("[Bot]Generate Tank based on total")
{
	事件
	{
		子程序;
		CreateTankBot;
	}

	动作
	{
		生成机器人(数组随机取值(全局.Tank), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(
			0, 0, 0));
		根据条件跳过(全局.TankBotTotal == 1, 3);
		生成机器人(数组随机取值(全局.Tank), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(
			0, 0, 0));
		根据条件跳过(全局.TankBotTotal == 2, 1);
		生成机器人(数组随机取值(全局.Tank), 队伍1, -1, 最近的可行走位置(所选位置(数组随机取值(所有存活玩家(队伍1))) + 矢量(随机实数(-1, 1), 随机实数(-1, 1), 随机实数(-1, 1)) * 随机实数(7, 10)), 矢量(
			0, 0, 0));
	}
}

