        "随机禁用英雄池中的4名英雄（1 重装 2输出 1辅助）"
        设置全局变量(Hero_BAN, 地图工坊设置开关(自定义字符串("模式"), 自定义字符串("英雄BAN池"), 假, 11));
        设置全局变量(CustomAI, 地图工坊设置组合(自定义字符串("模式"), 自定义字符串("自定义 AI"), 0, 数组(自定义字符串("弗蕾娅"), 自定义字符串("探奇"), 自定义字符串("法老之鹰"), 自定义字符串("伊拉锐"), 自定义字符串("朱诺"), 自定义字符串("骇灾"), 自定义字符串("斩仇")), 12));
    }
}

