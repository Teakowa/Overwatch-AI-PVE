        设置受到伤害(事件玩家, 减(100, (事件玩家).dmg_reduction));
        等待直到 (非(正在使用技能 2(事件玩家)), 3);
        修改玩家变量(事件玩家, dmg_reduction, 减, 数组中的值(全局.MaugaBuff, 4));
        设置受到伤害(事件玩家, 100);
    }
}

