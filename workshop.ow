规则 ("Changelog Content") {
    事件 {
        子程序;
        changelogText;
    }
    动作 {
        创建HUD文本(事件玩家, 空, 空, 自定义字符串(" \r\n\n"), 左边, 0, 空, 空, 真, 可见和字符串, 始终不可见);
        设置玩家变量(事件玩家, ChangelogText1, 上一个文本ID);
        If(比较(所用英雄(事件玩家), ==, 英雄(D.Va)));
            创建HUD文本(事件玩家, 空, 全局.Mark, 自定义字符串("\r\n●\"{0}\"\r\n*造成伤害 +35%\r\n*受到伤害 -25%\r\n{1} 防御矩阵\r\n 持续时间提高至 4 秒\r\n 完全充能时间由 6 秒降低至 3 秒\n\n※※离开重生室隐藏", 所用英雄(事件玩家), 技能图标字符串(所用英雄(事件玩家), 按钮(辅助攻击模式))), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
            设置玩家变量(事件玩家, ChangelogText2, 上一个文本ID);
        Else If(比较(所用英雄(事件玩家), ==, 英雄(末日铁拳)));
            创建HUD文本(事件玩家, 空, 全局.Mark, 自定义字符串("\r\n●{0}\r\n*造成伤害 +25%\r\n*受到伤害 -45%\r\n*裂地重拳\r\n  将敌人击飞拉近并使其失控\r\n*悍猛格挡 吸收并存储伤害\r\n*火箭重拳 附带悍猛格挡存储的全部伤害 对目标造成额外伤害\n\n※※离开重生室隐藏", 所用英雄(事件玩家)), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
            设置玩家变量(事件玩家, ChangelogText2, 上一个文本ID);
        Else If(比较(所用英雄(事件玩家), ==, 英雄(渣客女王)));
            创建HUD文本(事件玩家, 空, 全局.Mark, 自定义字符串("\r\n●{0}\r\n*造成伤害 +30%\r\n*受到伤害 -50%\r\n*血斩 冷却时间降低至 6 秒\r\n*锯齿利刃 冷却时间降低至 4 秒\n\n※※离开重生室隐藏", 所用英雄(事件玩家)), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
            设置玩家变量(事件玩家, ChangelogText2, 上一个文本ID);
        Else If(比较(所用英雄(事件玩家), ==, 英雄(毛加)));
            创建HUD文本(事件玩家, 空, 全局.Mark, 自定义字符串("\r\n●{0}\r\n*造成伤害 +25%\r\n*受到伤害 -35%\r\n*狂战士之魂（被动） 受到致命伤害触发 回复100%最大生命值并进入狂战士状态\r\n*蛮力冲撞 击倒时间提高至2秒\r\n*心脏过载 冷却时间降低至10秒 治疗量+100% 伤害减免60%\r\n{1}", 所用英雄(事件玩家), 自定义字符串("*笼中斗 持续时间提高并免疫暴击\r\n")), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
            设置玩家变量(事件玩家, ChangelogText2, 上一个文本ID);
        Else If(比较(所用英雄(事件玩家), ==, 英雄(奥丽莎)));
            创建HUD文本(事件玩家, 空, 全局.Mark, 自定义字符串("\r\n●{0}\r\n*受到伤害 -60%\r\n*强固防御\r\n  冷却时间降低至 12 秒\r\n  持续期间获得 额外临时护甲\r\n  反弹受到伤害的{1}%\r\n*标枪旋击\r\n  冷却时间增加至 8 秒\n\n※※离开重生室隐藏", 所用英雄(事件玩家), 数组中的值(全局.Orisa_Fortify, 1)), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
            设置玩家变量(事件玩家, ChangelogText2, 上一个文本ID);
        Else If(比较(所用英雄(事件玩家), ==, 英雄(拉玛刹)));
            创建HUD文本(事件玩家, 空, 全局.Mark, 自定义字符串("\r\n●{0}\r\n*造成伤害 +20%\r\n*受到伤害 -35%\r\n*吞噬漩涡 冷却时间降低\r\n* 诛 -{1}%受到伤害 +30%移速 70%击退抵抗\r\n回复{2}%已造成伤害的生命值\n\n※离开重生室隐藏", 所用英雄(事件玩家), 数组中的值(全局.Ram_Annihilation, 4), 乘(数组中的值(全局.Ram_Annihilation, 1), 100)), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
            设置玩家变量(事件玩家, ChangelogText2, 上一个文本ID);
