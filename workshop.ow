		全局.Counter_Bot = 空数组;
		修改全局变量(Counters, 添加至数组, 数组(英雄(D.Va),英雄(半藏), 英雄(士兵：76), 英雄(奥丽莎), 英雄(托比昂), 英雄(末日铁拳), 英雄(查莉娅), 英雄(死神), 英雄(法老之鹰), 英雄(源氏), 英雄(猎空), 英雄(破坏球),  英雄(美), 英雄(艾什), 英雄(莱因哈特), 英雄(西格玛), 英雄(卡西迪), 英雄(黑影), 英雄(伊拉锐), 英雄(拉玛刹), 英雄(渣客女王), 英雄(温斯顿), 英雄(索杰恩)));
		修改全局变量(Counter_Bot, 添加至数组, 数组(英雄(卢西奥), 英雄(禅雅塔), 英雄(布丽吉塔), 英雄(雾子), 英雄(黑影), 英雄(秩序之光)));
	}
}

规则("[Bot] Counter Ultimate Ability")
{
	事件
	{
		玩家受到伤害;
		队伍1;
		全部;
	}

	条件
	{
		(存活(事件玩家) && 终极技能充能百分比(事件玩家) == 100) == 真;
		事件技能 == 按钮(终极技能);
		数组包含(全局.Counter_Bot, 所用英雄(被攻击方)) == 真;
		数组包含(全局.Counters, 所用英雄(攻击方)) == 真;
	}

	动作
	{
		根据条件跳过(!正在使用终极技能(攻击方), 3);
		开始按下按钮(事件玩家, 按钮(终极技能));
		等待(2, 无视条件);
		停止按下按钮(事件玩家, 按钮(终极技能));
	}
}

规则("[Bot] Auto use Ultimate Ability")
{
	事件
	{
		玩家受到伤害;
		队伍1;
		全部;
	}

	条件
	{
		(存活(事件玩家) && 终极技能充能百分比(事件玩家) == 100) == 真;
		范围内玩家(事件玩家, 10, 对方队伍(所在队伍(事件玩家)), 表面) >= 3;
		范围内玩家(事件玩家, 15, 所在队伍(事件玩家), 表面) >= 3;
		数组包含(全局.Counter_Bot, 所用英雄(被攻击方)) == 假;
	}

	动作
	{
		开始按下按钮(事件玩家, 按钮(终极技能));
		等待(0.34, 无视条件);
		停止按下按钮(事件玩家, 按钮(终极技能));
	}
}

