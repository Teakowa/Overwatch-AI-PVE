        设置状态(被攻击方, 攻击方, 击倒, 2);
        根据条件跳过(或(或(或(具有状态(被攻击方, 无敌), 具有状态(被攻击方, 无法杀死)), 具有状态(被攻击方, 相移)), (被攻击方).has_nano), 1);
        伤害(被攻击方, 攻击方, 取整(乘(最大生命值(被攻击方), 数组中的值(全局.MaugaBuff, 3)), 上));
        //lbl_0:
        //lbl_1:
    }
}

