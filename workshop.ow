		根据条件跳过(数组包含(数组(地图(伊利奥斯), 地图(尼泊尔), 地图(漓江塔), 地图(釜山), 地图(绿洲城), 地图(巴黎), 地图(里阿尔托)), 当前地图), 1);
		修改全局变量(Heros, 根据索引从数组中移除, 随机实数(0, 7));
		修改全局变量(Heros, 根据索引从数组中移除, 随机实数(7, 21));
		修改全局变量(Heros, 根据索引从数组中移除, 随机实数(7, 20));
		根据条件跳过(!数组包含(数组(地图(伊利奥斯), 地图(尼泊尔), 地图(漓江塔), 地图(绿洲城), 地图(釜山)), 当前地图), 1);
		修改全局变量(Heros, 根据值从数组中移除, 英雄(卢西奥));
		根据条件跳过(数组包含(数组(地图(伊利奥斯), 地图(尼泊尔), 地图(漓江塔), 地图(绿洲城), 地图(釜山)), 当前地图), 1);
