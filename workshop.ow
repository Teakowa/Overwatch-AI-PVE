    }
    动作 {
        根据条件跳过(比较((事件玩家).mauga_berserker_soul, ==, 真), 1);
        调用子程序(resetStatuses);
        //lbl_0:
        在索引处设置玩家变量(事件玩家, zarya_barrier_shields, 0, 假);
        根据条件跳过(比较(数组中的值((事件玩家).zarya_barrier_shields, 1), ==, 空), 1);
        移除玩家的生命池(数组中的值((事件玩家).zarya_barrier_shields, 1));
        //lbl_1:
        为玩家添加生命池(事件玩家, 生命值, 50, 假, 假);
        在索引处设置玩家变量(事件玩家, zarya_barrier_shields, 1, 最后创建的生命池);
        等待(3, 当为“真”时重新开始);
        移除玩家的生命池(数组中的值((事件玩家).zarya_barrier_shields, 1));
        在索引处设置玩家变量(事件玩家, zarya_barrier_shields, 1, 空);
    }
}

