规则("[custom_hp.opy]: clearCustomHp()")
{
	事件
	{
		子程序;
		clearCustomHp;
	}

	动作
	{
		移除玩家的所有生命值(事件玩家);
		等待(0.016, 无视条件);
		"eventPlayer.setMaxHealth(100.001)\nwait()"
		设置最大生命值(事件玩家, 100);
	}
}

规则("[custom_hp.opy]: applyCustomHp()")
{
	事件
	{
		子程序;
		applyCustomHp;
	}

	动作
	{
		If(首个(事件玩家.custom_hp_pvar) + 事件玩家.custom_hp_pvar[1] + 事件玩家.custom_hp_pvar[2] <= 0);
			调用子程序(clearCustomHp);
			中止;
		End;
		等待直到 (已重生(事件玩家), 999999986991104.000);
		等待直到 (!(具有状态(事件玩家, 无敌) || 具有状态(事件玩家, 无法杀死)), 999999986991104.000);
		等待(0.016, 无视条件);
		设置受到治疗(事件玩家, 0);
		设置玩家生命值(事件玩家, 1);
		为玩家添加生命池(事件玩家, 生命值, 1, 真, 真);
		为玩家添加生命池(事件玩家, 护甲, 1, 真, 真);
		为玩家添加生命池(事件玩家, 护盾, 1, 真, 真);
		"Apply an unkillable status so we don't accidentally kill the player"
		设置状态(事件玩家, 事件玩家, 无法杀死, 999999986991104.000);
		"wait(0.064)"
		等待(0.016, 无视条件);
		移除玩家的所有生命值(事件玩家);
		等待直到 (最大生命值(事件玩家) <= 1, 1);
		"Apply custom health pool to player"
		If(首个(事件玩家.custom_hp_pvar) > 0);
			为玩家添加生命池(事件玩家, 生命值, 较大(1, 首个(事件玩家.custom_hp_pvar) - 1), 真, 真);
		End;
		If(事件玩家.custom_hp_pvar[1] > 0);
			为玩家添加生命池(事件玩家, 护甲, 较大(1, 事件玩家.custom_hp_pvar[1]), 真, 真);
		End;
		If(事件玩家.custom_hp_pvar[2] > 0);
			为玩家添加生命池(事件玩家, 护盾, 较大(1, 事件玩家.custom_hp_pvar[2]), 真, 真);
		End;
		治疗(事件玩家, 空, 999999986991104.000);
		清除状态(事件玩家, 无法杀死);
		"Restore normal healing"
		设置受到治疗(事件玩家, 100);
	}
}

规则("[utilities/reset.opy]: resetHero()")
{
	事件
	{
		子程序;
		resetHero;
	}

	动作
	{
		开始规则(clearCustomHp, 重新开始规则);
		开始规则(resetStats, 重新开始规则);
		开始规则(resetStatuses, 重新开始规则);
		开始规则(resetFrenemies, 重新开始规则);
		开始规则(enableAllAbilities, 重新开始规则);
		If(全局.random_size == 真);
			开始规则(randomSize, 重新开始规则);
		End;
		"wait at least 1 tick"
		等待(0.016, 无视条件);
	}
}

