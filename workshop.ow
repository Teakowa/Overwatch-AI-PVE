规则 ("[utilities/reset]: setup var when player joins lobby") {
    事件 {
        持续 - 每名玩家;
        双方;
        全部;
    }
    动作 {
        调用子程序(resetFrenemies);
    }
}

规则 ("[utilities/reset]: Default respawn time") {
    事件 {
        持续 - 每名玩家;
        队伍1;
        全部;
    }
    动作 {
        设置最大复生时间(事件玩家, 5);
    }
}

