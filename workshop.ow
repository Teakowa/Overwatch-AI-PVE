规则("[Ana]: Sleep tanks for longer duration")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		(正在复制的英雄(事件玩家) == 英雄(安娜) || 所用英雄(事件玩家) == 英雄(安娜)) == 真;
		事件技能 == 按钮(技能1);
		数组包含(所有重装英雄, 所用英雄(被攻击方)) == 真;
	}

	动作
	{
		等待直到 (具有状态(被攻击方, 沉睡), 999999986991104.000);
		设置状态(被攻击方, 攻击方, 沉睡, 999999986991104.000);
		等待直到 (!具有状态(被攻击方, 沉睡), 5);
		清除状态(被攻击方, 沉睡);
		设置移动速度(被攻击方, 100);
	}
}

禁用 规则("[doomfist] disable uppercut when Cassidy use magnetic grenade")
{
	事件
	{
		玩家受到伤害;
		双方;
		末日铁拳;
	}

	条件
	{
		全局.OW1_DOOMFIST == 真;
		(正在复制的英雄(事件玩家) == 英雄(卡西迪) || 所用英雄(事件玩家) == 英雄(卡西迪)) == 真;
		事件技能 == 按钮(技能2);
		事件伤害 <= 10;
	}

	动作
	{
		事件玩家.magnetic_grenade = 真;
		设置启用技能 2(事件玩家, 假);
		等待(1.200, 无视条件);
		事件玩家.magnetic_grenade = 假;
		设置启用技能 2(事件玩家, 真);
	}
}

规则("[doomfist/uppercut.opy]: Control flow for uppercut")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.OW1_DOOMFIST == 真;
		(正在复制的英雄(事件玩家) == 英雄(末日铁拳) || 所用英雄(事件玩家) == 英雄(末日铁拳)) == 真;
		正在使用技能 2(事件玩家) == 真;
		正在使用技能 1(事件玩家) == 假;
		正在使用辅助武器(事件玩家) == 假;
		事件玩家.magnetic_grenade == 假;
	}

	动作
	{
		"cancel Power Block animation"
		取消主要动作(事件玩家);
		设置启用技能 2(事件玩家, 假);
		设置技能冷却(事件玩家, 按钮(技能2), 0);
		调用子程序(executeUppercut);
	}
}

规则("[doomfist/uppercut.opy]: executeUppercut()")
{
	事件
	{
		子程序;
		executeUppercut;
	}

	动作
	{
		"Start of uppercut"
		事件玩家.is_using_uppercut = 真;
		施加推力(事件玩家, 速率(事件玩家), -1 * 速度(事件玩家), 至地图, 合并相反运动);
		"Doomfist phases through enemies during uppercut"
		取消与玩家的移动碰撞(事件玩家);
		"Disable abilities during uppercut"
		事件玩家.is_uppercut_locked = 真;
		"Uppercut physics\n Step Forward"
		施加推力(事件玩家, 地图矢量(前, 事件玩家, 旋转), 5, 至地图, 合并相反运动);
		"Override gravity during uppercut"
		设置引力(事件玩家, 0);
		"Deny player from inputting movement commands"
		开始限制阈值(事件玩家, 0, 0, 0, 0, 0, 0);
		等待(0.150, 无视条件);
		"Uppercut"
		施加推力(事件玩家, 上, 40, 至地图, 合并相反运动);
		等待(0.100, 无视条件);
		施加推力(事件玩家, 下, 较大(0, 指定方向速度(事件玩家, 上)), 至地图, 合并相反运动);
		"Reenable abilities"
		事件玩家.is_uppercut_locked = 假;
		等待(0.016, 无视条件);
		施加推力(事件玩家, 上, 2.500, 至地图, 合并相反运动);
		开启与玩家的移动碰撞(事件玩家);
		等待(0.350, 无视条件);
		"End of uppercut"
		事件玩家.is_using_uppercut = 假;
		停止限制阈值(事件玩家);
		等待(0.150, 无视条件);
		根据条件中止(正在使用技能 1(事件玩家));
		设置引力(事件玩家, 50);
		等待(0.250, 无视条件);
		根据条件中止(正在使用技能 1(事件玩家));
		设置引力(事件玩家, 100);
	}
}

规则("[doomfist/uppercut.opy]: Disable abilities when locked into uppercut")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		全局.OW1_DOOMFIST == 真;
		(正在复制的英雄(事件玩家) == 英雄(末日铁拳) || 所用英雄(事件玩家) == 英雄(末日铁拳)) == 真;
		事件玩家.is_uppercut_locked != 假;
	}

	动作
	{
		事件玩家.is_uppercut_locked = 真;
		"Doomfist cannot melee during uppercut"
		设置启用近战攻击(事件玩家, 假);
		"Doomfist cannot shoot during uppercut"
		设置主要攻击模式启用(事件玩家, 假);
		"Doomfist cannot punch during uppercut"
		设置辅助攻击模式启用(事件玩家, 假);
		"Doomfist cannot slam during uppercut"
		设置启用技能 1(事件玩家, 假);
		等待直到 (!事件玩家.is_uppercut_locked, 999999986991104.000);
		设置启用近战攻击(事件玩家, 真);
		设置主要攻击模式启用(事件玩家, 真);
		"Shoot single buffered left click interrupted by power block"
		If(按钮被按下(事件玩家, 按钮(主要攻击模式)));
			按下按键(事件玩家, 按钮(主要攻击模式));
		End;
		设置辅助攻击模式启用(事件玩家, 真);
		设置启用技能 1(事件玩家, 真);
	}
}

