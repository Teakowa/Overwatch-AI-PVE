规则 ("[utilities/reset.opy]: resetHero()") {
    事件 {
        子程序;
        resetHero;
    }
    动作 {
        消除HUD文本(数组中的值((事件玩家).reaper_buff, 2));
        消除HUD文本((事件玩家).ram_block_damage_hud);
        消除HUD文本((事件玩家).sigma_hyperspheres_hud);
        消除HUD文本((事件玩家).doom_buff_hud);
        在索引处设置玩家变量(事件玩家, reaper_buff, 2, 0);
        设置玩家变量(事件玩家, hudText, 自定义字符串(""));
        设置玩家变量(事件玩家, ram_block_damage, 0);
        设置玩家变量(事件玩家, sigma_hyperspheres, 0);
        设置玩家变量(事件玩家, doom_buff, 0);
        在索引处设置玩家变量(事件玩家, reaper_buff, 1, 0);
        设置玩家变量(事件玩家, dmg_reduction, 0);
        设置玩家变量(事件玩家, dmg_amplification, 0);
        设置玩家变量(事件玩家, has_nano, 假);
        调用子程序(clearCustomHp);
        调用子程序(resetStats);
        调用子程序(resetStatuses);
        调用子程序(resetFrenemies);
        调用子程序(enableAllAbilities);
        "wait at least 1 tick"
        等待(0.016, 无视条件);
    }
}

禁用 规则 ("[passives/tank/knockback.opy]: removeTankPassive()") {
    事件 {
        子程序;
        removeTankPassive;
    }
    动作 {
        设置受到的击退(事件玩家, 166.667);
    }
}

规则 ("[utilities/overhealth]: Store Overhealth") {
    事件 {
        子程序;
        storeOverhealth;
    }
    动作 {
        在索引处设置玩家变量(事件玩家, storedOverhealth, 0, 减(减(减(最大生命值(事件玩家), 类型的最大生命值(事件玩家, 生命值)), 类型的最大生命值(事件玩家, 护甲)), 类型的最大生命值(事件玩家, 护盾)));
    }
}

规则 ("[AI/global]: botAim2Target") {
    事件 {
        子程序;
        botAim2Target;
    }
    动作 {
        开始朝向(事件玩家, 方向(加(加(事件玩家, 乘(上, 相距距离(事件玩家, 眼睛位置(事件玩家)))), 地图矢量(矢量(0, 0, 0), 事件玩家, 旋转)), 眼睛位置((事件玩家).botTarget)), 10000, 至地图, 方向及角速率);
    }
}

禁用 规则 ("Initialize AI Scripts") {
    事件 {
        持续 - 全局;
    }
}

规则 ("[AI/global]: Generated at the beginning") {
    事件 {
        持续 - 全局;
    }
    条件 {
        对任意为“真”(数组(正在等待玩家, 正在设置, 游戏正在进行中), 当前数组元素) == 真;
