禁用 规则("### Bot Rename End ###")
{
	事件
	{
		持续 - 全局;
	}
}

规则("[Torbjörn] Forge Hammer Healing Bastion")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		托比昂;
	}

	条件
	{
		处于非初始状态(事件玩家) == 真;
		正在使用主要武器(事件玩家) == 真;
		相距距离(事件玩家, 选择英雄的玩家(英雄(堡垒), 所在队伍(事件玩家))) <= 2.500;
		在视野内(事件玩家, 选择英雄的玩家(英雄(堡垒), 所在队伍(事件玩家)), 45) == 真;
	}

	动作
	{
		治疗(选择英雄的玩家(英雄(堡垒), 所在队伍(事件玩家)), 事件玩家, 50);
		播放效果(事件玩家, 正面状态施加声音, 颜色(黄色), 事件玩家, 200);
	}
}

规则("[Ana] Nano Boost Dmg. reduction Change")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		事件玩家.anna == 真;
	}

	动作
	{
		等待(0.250, 无视条件);
		设置受到伤害(事件玩家, 70);
		等待(7.750, 无视条件);
		设置受到伤害(事件玩家, 100);
	}
}

规则("[Lucio] Shorten the cooldown time of Amp It Up after Sonic Amplifier hit")
{
	事件
	{
		玩家造成伤害;
		双方;
		卢西奥;
	}

	条件
	{
		技能冷却时间(事件玩家, 按钮(技能2)) > 0;
		事件技能 == 按钮(主要攻击模式);
	}

	动作
	{
		设置技能冷却(事件玩家, 按钮(技能2), 技能冷却时间(事件玩家, 按钮(技能2)) - 0.250);
	}
}

规则("[Pharah] Return fuel after dealing damage")
{
	事件
	{
		玩家造成伤害;
		双方;
		法老之鹰;
	}

	条件
	{
		技能资源(事件玩家, 按钮(跳跃)) < 100;
		被攻击方 != 事件玩家;
	}

	动作
	{
		设置技能资源(事件玩家, 按钮(跳跃), 技能资源(事件玩家, 按钮(跳跃)) + 事件伤害 * 0.300);
	}
}

规则("[Wrecking Ball] Roll Dmg. reduction")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		破坏球;
	}

	条件
	{
		(处于非初始状态(事件玩家) || 正在使用技能 1(事件玩家)) == 真;
	}

	动作
	{
		设置受到伤害(事件玩家, 85);
		等待直到 (!处于非初始状态(事件玩家) || !正在使用技能 1(事件玩家), 99999);
		设置受到伤害(事件玩家, 100);
	}
}

规则("[Sombra] Setup Target")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		黑影;
	}

	条件
	{
		(英雄数量(英雄(安娜), 对方队伍(所在队伍(事件玩家))) != 0 || 英雄数量(英雄(禅雅塔), 对方队伍(所在队伍(事件玩家))) != 0 || 英雄数量(英雄(巴蒂斯特), 对方队伍(所在队伍(事件玩家))) != 0 || 假) == 真;
	}

	动作
	{
		如条件为“假”则中止;
		根据条件跳过(英雄数量(英雄(安娜), 对方队伍(所在队伍(事件玩家))) == 0, 1);
		事件玩家.reset_pvar[9] = 选择英雄的玩家(英雄(安娜), 对方队伍(所在队伍(事件玩家)));
		根据条件跳过(英雄数量(英雄(禅雅塔), 对方队伍(所在队伍(事件玩家))) == 0, 1);
		事件玩家.reset_pvar[9] = 选择英雄的玩家(英雄(禅雅塔), 对方队伍(所在队伍(事件玩家)));
		根据条件跳过(英雄数量(英雄(巴蒂斯特), 对方队伍(所在队伍(事件玩家))) == 0, 1);
		事件玩家.reset_pvar[9] = 选择英雄的玩家(英雄(巴蒂斯特), 对方队伍(所在队伍(事件玩家)));
		根据条件跳过(英雄数量(英雄(伊拉锐), 对方队伍(所在队伍(事件玩家))) == 0, 1);
		事件玩家.reset_pvar[9] = 选择英雄的玩家(英雄(伊拉锐), 对方队伍(所在队伍(事件玩家)));
		根据条件跳过(英雄数量(英雄(黑百合), 对方队伍(所在队伍(事件玩家))) == 0, 1);
		事件玩家.reset_pvar[9] = 选择英雄的玩家(英雄(黑百合), 对方队伍(所在队伍(事件玩家)));
		等待(5, 无视条件);
		如条件为“真”则循环;
	}
}

规则("[Sombra] TP to Support")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		黑影;
	}

	条件
	{
		速度(事件玩家) >= 7;
		(存活(首个(事件玩家.reset_pvar[9])) && !在重生室中(首个(事件玩家.reset_pvar[9]))) == 真;
		(!在目标点上(事件玩家) || !在重生室中(事件玩家)) == 真;
		相距距离(事件玩家, 首个(事件玩家.reset_pvar[9])) >= 5.500;
		禁用 相距距离(距离最近的玩家(事件玩家, 所在队伍(事件玩家)), 首个(事件玩家.reset_pvar[9])) <= 30;
		禁用 在视线内(事件玩家, 距离最近的玩家(事件玩家, 所在队伍(事件玩家)), 屏障不会阻挡视线) == 真;
		在地面上(事件玩家) == 真;
		正在使用技能 1(事件玩家) == 假;
		正在使用技能 2(事件玩家) == 假;
		正在使用辅助武器(事件玩家) == 假;
	}

	动作
	{
		等待(3, 当为“假”时中止);
		传送(事件玩家, 最近的可行走位置(首个(事件玩家.reset_pvar[9]) - 地图矢量(矢量(0, 0, -7), 事件玩家, 旋转)));
		如条件为“真”则循环;
	}
}

规则("[Brigitte] Reduce Shield Bash cooldown after Whip Shot Hit")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		(正在复制的英雄(事件玩家) == 英雄(布丽吉塔) || 所用英雄(事件玩家) == 英雄(布丽吉塔)) == 真;
		事件技能 == 按钮(技能1);
	}

	动作
	{
		设置技能冷却(事件玩家, 按钮(主要攻击模式), 技能冷却时间(事件玩家, 按钮(主要攻击模式)) - 1);
	}
}

规则("[Zenyatta] Snap Kick (enemy)")
{
	事件
	{
		玩家受到伤害;
		双方;
		全部;
	}

	条件
	{
		(正在复制的英雄(攻击方) == 英雄(禅雅塔) || 所用英雄(攻击方) == 英雄(禅雅塔)) == 真;
		事件技能 == 按钮(近身攻击);
	}

	动作
	{
		事件玩家.KnockbackDirection = 与此角度的相对方向(水平朝向角度(攻击方), -10);
		开始限制阈值(事件玩家, 0, 0, 0, 0, 0, 0.500);
		调用子程序(Knockback);
		伤害(事件玩家, 攻击方, 事件伤害 * 0.500);
		事件玩家.isKnocked = 真;
	}
}

规则("[Zenyatta] Sub Knockback")
{
	事件
	{
		子程序;
		Knockback;
	}

	动作
	{
		等待(0.016, 无视条件);
		施加推力(事件玩家, 事件玩家.KnockbackDirection, 全局.WorkshopKnockupStrength, 至地图, 取消相反运动);
		施加推力(事件玩家, 上, 全局.WorkshopKnockupStrength * 0.300, 至地图, 取消相反运动);
	}
}

规则("[Zenyatta] Snap Kick (Self Ground)")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		(正在复制的英雄(事件玩家) == 英雄(禅雅塔) || 所用英雄(事件玩家) == 英雄(禅雅塔)) == 真;
		已重生(事件玩家) == 真;
		存活(事件玩家) == 真;
		正在近战攻击(事件玩家) == 按钮(近身攻击);
		垂直朝向角度(事件玩家) >= 45;
	}

	动作
	{
		If(相距距离(射线命中位置(眼睛位置(事件玩家), 眼睛位置(事件玩家) + 面朝方向(事件玩家) * 2.510, 所有玩家(所有队伍), 事件玩家, 真), 眼睛位置(事件玩家)) <= 2.500);
			事件玩家.KnockbackDirection = 面朝方向(事件玩家) * -1;
			调用子程序(Knockback);
		End;
	}
}

规则("[Zenyatta] stop knocked")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		事件玩家.isKnocked == 真;
	}

	动作
	{
		等待(0.016, 当为“假”时中止);
		停止限制阈值(事件玩家);
		事件玩家.isKnocked = 假;
	}
}

规则("[Zenyatta] Snap Kick (Self Wall)")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		全部;
	}

	条件
	{
		(正在复制的英雄(事件玩家) == 英雄(禅雅塔) || 所用英雄(事件玩家) == 英雄(禅雅塔)) == 真;
		正在近战攻击(事件玩家) == 按钮(近身攻击);
		已重生(事件玩家) == 真;
		存活(事件玩家) == 真;
		垂直朝向角度(事件玩家) < 45;
	}

	动作
	{
		If(相距距离(射线命中位置(眼睛位置(事件玩家), 眼睛位置(事件玩家) + 面朝方向(事件玩家) * 2.510, 所有玩家(所有队伍), 事件玩家, 真), 眼睛位置(事件玩家)) <= 2.500);
			If(射线命中玩家(眼睛位置(事件玩家), 眼睛位置(事件玩家) + 面朝方向(事件玩家) * 5, 所有玩家(所有队伍), 事件玩家, 真) == 空);
				事件玩家.KnockbackDirection = 面朝方向(事件玩家) * -1;
				调用子程序(Knockback);
			End;
		End;
	}
}

