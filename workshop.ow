规则("[Sombra] Setup Target")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		黑影;
	}

	条件
	{
		(英雄数量(英雄(安娜), 对方队伍(所在队伍(事件玩家))) != 0 || 英雄数量(英雄(禅雅塔), 对方队伍(所在队伍(事件玩家))) != 0 || 英雄数量(英雄(巴蒂斯特), 对方队伍(所在队伍(事件玩家))) != 0 || 假) == 真;
	}

	动作
	{
		根据条件跳过(英雄数量(英雄(安娜), 对方队伍(所在队伍(事件玩家))) == 0, 1);
		事件玩家.T = 选择英雄的玩家(英雄(安娜), 对方队伍(所在队伍(事件玩家)));
		根据条件跳过(英雄数量(英雄(禅雅塔), 对方队伍(所在队伍(事件玩家))) == 0, 1);
		事件玩家.T = 选择英雄的玩家(英雄(禅雅塔), 对方队伍(所在队伍(事件玩家)));
		根据条件跳过(英雄数量(英雄(巴蒂斯特), 对方队伍(所在队伍(事件玩家))) == 0, 1);
		事件玩家.T = 选择英雄的玩家(英雄(巴蒂斯特), 对方队伍(所在队伍(事件玩家)));
		等待(5, 无视条件);
		如条件为”真“则循环;
	}
}

规则("[Sombra] TP to Support")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		黑影;
	}

	条件
	{
		正在使用技能 1(事件玩家) == 真;
		(存活(事件玩家.T) && !在重生室中(事件玩家.T)) == 真;
		(!在目标点上(事件玩家) || !在重生室中(事件玩家)) == 真;
		相距距离(事件玩家, 事件玩家.T) >= 4.500;
		相距距离(选择英雄的玩家(英雄(路霸), 所在队伍(事件玩家)), 事件玩家.T) <= 30;
	}

	动作
	{
		等待(1, 当为“假”时中止);
		根据条件跳过(在目标点上(事件玩家) == 真, 1);
		传送(事件玩家, 最近的可行走位置(事件玩家.T));
		如条件为”真“则循环;
	}
}

