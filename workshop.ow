规则("[widowmaker.opy]: Revert sniper damage falloff")
{
	事件
	{
		玩家造成伤害;
		双方;
		全部;
	}

	条件
	{
		(正在复制的英雄(事件玩家) == 英雄(黑百合) || 所用英雄(事件玩家) == 英雄(黑百合)) == 真;
		正在使用辅助武器(事件玩家) == 真;
		正在使用主要武器(事件玩家) == 真;
		事件技能 == 按钮(主要攻击模式);
	}

	动作
	{
		事件玩家.scoped_shot_distance = 相距距离(眼睛位置(攻击方), 被攻击方);
		事件玩家.ow2_scoped_damage_falloff_scalar = (事件玩家.scoped_shot_distance - 50) / 20 * 0.500 + (1 - (事件玩家.scoped_shot_distance - 50)
			/ 20);
		"Cap min/max scalar\n Max damage scalar"
		If(事件玩家.ow2_scoped_damage_falloff_scalar > 1);
			事件玩家.ow2_scoped_damage_falloff_scalar = 1;
		"Min damage scalar"
		Else If(事件玩家.ow2_scoped_damage_falloff_scalar < 0.500);
			事件玩家.ow2_scoped_damage_falloff_scalar = 0.500;
		End;
		事件玩家.scoped_damage_base = 事件伤害 / 事件玩家.ow2_scoped_damage_falloff_scalar;
		事件玩家.ow1_scoped_damage_falloff_scalar = (事件玩家.scoped_shot_distance - 70) / 30 * 0.300 + (1 - (事件玩家.scoped_shot_distance - 70)
			/ 30);
		"Cap min/max scalar\n Max damage scalar"
		If(事件玩家.ow1_scoped_damage_falloff_scalar > 1);
			事件玩家.ow1_scoped_damage_falloff_scalar = 1;
		"Min damage scalar"
		Else If(事件玩家.ow1_scoped_damage_falloff_scalar < 0.300);
			事件玩家.ow1_scoped_damage_falloff_scalar = 0.300;
		End;
		事件玩家.expected_scoped_damage = 事件玩家.scoped_damage_base * 事件玩家.ow1_scoped_damage_falloff_scalar;
		伤害(被攻击方, 攻击方, 事件玩家.expected_scoped_damage - 事件伤害);
	}
}


