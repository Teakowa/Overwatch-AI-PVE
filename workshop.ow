		创建HUD文本(事件玩家, 空, 自定义字符串("治疗被动激活 = {0}", 事件玩家.self_heal_pvar[3]), 空, 右边, 1, 空, 颜色(白色), 空, 字符串, 默认可见度);
		创建HUD文本(事件玩家, 空, 自定义字符串("len(self_healing_source) = {0}", 数量(首个(事件玩家.self_heal_pvar))), 空, 右边, 1, 空, 颜色(白色), 空, 字符串, 默认可见度);
