禁用 规则("[Lúcio] Crossfade Damage")
{
	事件
	{
		持续 - 每名玩家;
		双方;
		卢西奥;
	}

	条件
	{
		正在使用技能 1(事件玩家) == 真;
		具有状态(事件玩家, 被入侵) == 假;
		具有状态(事件玩家, 击倒) == 假;
		具有状态(事件玩家, 沉睡) == 假;
		具有状态(事件玩家, 冰冻) == 假;
		具有状态(事件玩家, 击晕) == 假;
		正在使用表情交流(事件玩家) == 假;
	}

	动作
	{
		开始持续伤害(已过滤的数组(范围内玩家(事件玩家, 12, 对方队伍(所在队伍(事件玩家)), 表面及敌方屏障), 在视线内(事件玩家, 当前数组元素, 敌方屏障阻挡视线) == 真 && 存活(当前数组元素) == 真), 事件玩家, 0.500,
			正在使用技能 2(事件玩家) == 真 ? 20 : 10);
		等待(0.500, 无视条件);
		如条件为“真”则循环;
	}
}

