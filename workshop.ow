规则("[Bot][Function]Create Bot")
{
	事件
	{
		子程序;
		createBot;
	}

	动作
	{
		根据条件跳过(比较(数量(已过滤的数组(所有玩家(队伍1), 是否是机器人(当前数组元素))), <, 2), 2);
		小字体信息(主机玩家, 自定义字符串("AI 数量超出限制", 无, 无, 无));
		中止;
		生成机器人(英雄(艾什), 队伍1, -1.000, 最近的可行走位置(加(所选位置(数组随机取值(所有存活玩家(队伍1))), 乘(矢量(随机实数(-1.000, 1), 随机实数(-1.000, 1), 随机实数(-1.000, 1)), 随机实数(7,
			10)))), 矢量(0, 0, 0));
		生成机器人(英雄(末日铁拳), 队伍1, -1.000, 最近的可行走位置(加(所选位置(数组随机取值(所有存活玩家(队伍1))), 乘(矢量(随机实数(-1.000, 1), 随机实数(-1.000, 1), 随机实数(-1.000, 1)), 随机实数(7,
			10)))), 矢量(0, 0, 0));
		等待(0.500, 无视条件);
	}
}

