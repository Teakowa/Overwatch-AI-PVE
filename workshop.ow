			创建HUD文本(事件玩家, 空, 自定义字符串(" \r\n\r\n\n 非重装 AI 伤害减免 25%\r\n 重装 AI 最高伤害减免 40%\r\n 完整更新日志 workshop.codes/3TP7F/update-log\r\n 坐牢交流群: 361913638"), 自定义字符串(
				"\r\n●{0}\r\n*重生\r\n  默认冷却60秒\r\n  每1击杀助攻减少2秒\r\n*女武神\r\n  受到伤害 -{1}%\r\n  持续期间 重生 冷却时间减半\n\n※※离开重生室隐藏", 所用英雄(
				事件玩家), 全局.Mercy_ValkyrieDmgReduction), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
			事件玩家.ChangelogText2 = 上一个文本ID;
		Else If(所用英雄(事件玩家) == 英雄(禅雅塔));
			创建HUD文本(事件玩家, 空, 自定义字符串(" \r\n\r\n\n 非重装 AI 伤害减免 25%\r\n 重装 AI 最高伤害减免 40%\r\n 完整更新日志 workshop.codes/3TP7F/update-log\r\n 坐牢交流群: 361913638"), 自定义字符串(
				"\r\n●{0}\r\n*造成伤害 +60%\r\n  暴击倍率提高至 ×{1}\r\n* 蹬\r\n  将禅雅塔向相反方向击飞\r\n* 圣\r\n  治疗量提高至400/s 移速+25% 无法被命中 免疫所有控制\n\n※※离开重生室隐藏", 所用英雄(事件玩家), 1 + 全局.HeadshotDamage[0]), 左边, 1, 颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
			事件玩家.ChangelogText2 = 上一个文本ID;
		Else If(所用英雄(事件玩家) == 英雄(莫伊拉));
			创建HUD文本(事件玩家, 空, 自定义字符串(" \r\n\r\n\n 非重装 AI 伤害减免 25%\r\n 重装 AI 最高伤害减免 40%\r\n 完整更新日志 workshop.codes/3TP7F/update-log\r\n 坐牢交流群: 361913638"), 自定义字符串(
				"\r\n●{0}\r\n*消散 冷却时间增加至 8 秒\n\n※※离开重生室隐藏", 所用英雄(事件玩家), 技能图标字符串(所用英雄(事件玩家), 按钮(技能2)), 技能图标字符串(所用英雄(事件玩家), 按钮(终极技能))), 左边, 1,
				颜色(白色), 颜色(白色), 颜色(白色), 可见和字符串, 始终不可见);
			事件玩家.ChangelogText2 = 上一个文本ID;
		End;
	}
}