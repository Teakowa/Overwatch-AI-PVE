规则("【布丽吉塔】盾击伤害调整至 30")
{
	事件
	{
		玩家受到伤害;
		队伍1;
		全部;
	}

	条件
	{
		攻击方 == 选择英雄的玩家(英雄(布丽吉塔), 队伍2);
		正在使用辅助武器(选择英雄的玩家(英雄(布丽吉塔), 队伍2)) == 真;
		按钮被按下(选择英雄的玩家(英雄(布丽吉塔), 队伍2), 主要攻击模式) == 真;
	}

	动作
	{
		禁用 设置状态(被攻击方, 攻击方, 昏迷, 3.200);
		伤害(事件玩家, 攻击方, 25);
		等待(4.500, 当为“假”时中止);
	}
}

