	}
}

规则("【美】使用急冻会停止时间流逝并且冰冻半径10米内的敌人")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		美;
	}

	条件
	{
		禁用 正在使用终极技能(事件玩家) == 真;
		正在使用技能 1(事件玩家) == 真;
	}

	动作
	{
		设置状态(范围内玩家(事件玩家, 10, 队伍2, 表面及全部屏障), 无, 冻结, 3.500);
		比赛时间暂停;
		等待(4, 无视条件);
		比赛时间继续;
	}
}

禁用 规则("【美】使用急冻会停止时间流逝")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		美;
	}

	条件
	{
		正在使用技能 1(选择英雄的玩家(英雄(美), 队伍1)) == 真;
	}

	动作
	{
		比赛时间暂停;
		等待(5, 无视条件);
		比赛时间继续;
	}
}

禁用 规则("【美】使用急冻后冰冻半径10米内的敌人")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		美;
	}

	条件
	{
		正在使用技能 1(事件玩家) == 真;
	}

	动作
	{
		治疗(事件玩家, 事件玩家, 乘(最大生命值(事件玩家), 0.250));
		设置玩家变量(事件玩家, Abi_1, 真);
	}
}

禁用 规则("【美】使用急冻后冰冻半径10米内的敌人")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		美;
	}

	条件
	{
		正在使用技能 1(事件玩家) != 真;
		玩家变量(事件玩家, Abi_1) == 真;
	}

	动作
	{
