	{
		持续 - 每名玩家;
		队伍2;
		末日铁拳;
	}

	条件
	{
		正在使用终极技能(事件玩家) == 真;
	}

	动作
	{
		设置状态(事件玩家, 无, 消散, 1);
		等待(0.250, 当为“假”时中止);
		如条件为”真“则循环;
	}
}

规则("【黑影】隐身状态下不会被控制")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		黑影;
	}

	条件
	{
		正在使用技能 1(事件玩家) == 真;
	}

	动作
	{
		清除状态(事件玩家, 冻结);
		清除状态(事件玩家, 定身);
		等待(0.250, 当为“假”时中止);
		如条件为”真“则循环;
	}
}

规则("【莫伊拉】消散解除定身效果")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		莫伊拉;
	}

	条件
	{
		正在使用技能 1(事件玩家) == 真;
		禁用 或(具有状态(事件玩家, 定身), 具有状态(事件玩家, 冻结)) == 真;
	}

	动作
	{
		禁用 设置状态(事件玩家, 无, 消散, 1);
		清除状态(事件玩家, 冻结);
		清除状态(事件玩家, 定身);
		等待(0.100, 当为“假”时中止);
		如条件为”真“则循环;
	}
}

规则("【安娜】禁疗瓶拥有燃烧效果")
{
	事件
	{
		玩家受到伤害;
		队伍2;
		全部;
	}

	条件
	{
		攻击方 == 选择英雄的玩家(英雄(安娜), 队伍1);
		正在使用技能 2(选择英雄的玩家(英雄(安娜), 队伍1)) == 真;
	}

	动作
	{
		设置状态(事件玩家, 攻击方, 点燃, 5);
		开始持续伤害(事件玩家, 攻击方, 5, 7);
	}
}

规则("【奥丽莎】强固防御反弹伤害")
{
	事件
	{
		玩家受到伤害;
		队伍2;
		奥丽莎;
	}

	条件
	{
		正在使用技能 1(事件玩家) == 真;
	}

	动作
	{
		伤害(攻击方, 事件玩家, 乘(事件伤害, 0.500));
		治疗(事件玩家, 无, 乘(事件伤害, 0.450));
	}
}

