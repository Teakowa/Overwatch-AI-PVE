	}

	条件
	{
		游戏正在进行中 == 真;
	}

	动作
	{
		设置全局变量(T, 6);
	}
}

规则("【玩家变量】初始化")
{
	事件
	{
		玩家加入比赛;
		队伍2;
		全部;
	}

	动作
	{
		设置玩家变量(事件玩家, moveSpeedDefault, 100);
		设置玩家变量(事件玩家, moveSpeed, 100);
		设置玩家变量(事件玩家, dealtDamageDefault, 100);
		设置玩家变量(事件玩家, dealtDamage, 100);
	}
}

