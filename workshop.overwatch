规则("默认重生时间")
{
	事件
	{
		玩家阵亡;
		队伍2;
		全部;
	}

	条件
	{
		死亡数(事件玩家) < 3;
	}

	动作
	{
		设置最大重生时间(事件玩家, 6);
	}
}

规则("【濒死debuff】重置 debuff")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		生命值(事件玩家) > 乘(最大生命值(事件玩家), 0.350);
	}

	动作
	{
		设置移动速度(事件玩家, 100);
		设置造成伤害(事件玩家, 100);
		禁用 设置造成治疗(事件玩家, 100);
	}
}

规则("【濒死debuff】")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		生命值(事件玩家) <= 乘(最大生命值(事件玩家), 0.350);
	}

	动作
	{
		大字体信息(事件玩家, 自定义字符串("濒死！", 无, 无, 无));
		禁用 修改玩家变量(事件玩家, moveSpeed, 减, 25);
		禁用 修改玩家变量(事件玩家, dealtDamage, 减, 25);
		设置移动速度(事件玩家, 减(玩家变量(事件玩家, moveSpeedDefault), 25));
		设置造成伤害(事件玩家, 减(玩家变量(事件玩家, dealtDamageDefault), 30));
		禁用 设置造成治疗(事件玩家, 75);
	}
}

规则("AI 获得 3/s HP 恢复")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		全部;
	}

	条件
	{
		游戏正在进行中 == 真;
	}

	动作
	{
		开始持续治疗(事件玩家, 事件玩家, 9999, 3.333);
	}
}

规则("死亡次数大于等于 4 获得 2 倍复活时间惩罚")
{
	事件
	{
		玩家阵亡;
		队伍2;
		全部;
	}

	条件
	{
		死亡数(事件玩家) >= 4;
		死亡数(事件玩家) < 8;
	}

	动作
	{
		设置最大重生时间(事件玩家, 乘(6, 2));
		设置移动速度(事件玩家, 100);
		等待(0.250, 无视条件);
		大字体信息(所有玩家(队伍2), 字符串("{0} {1}", 英雄图标字符串(所用英雄(事件玩家)), 自定义字符串("重生时间加时！", 无, 无, 无), 无));
	}
}

