规则("死亡次数大于等于 30 激活彩蛋")
{
	事件
	{
		玩家阵亡;
		队伍2;
		全部;
	}

	条件
	{
		死亡数(事件玩家) >= 30;
	}

	动作
	{
		根据条件中止(比较(全局变量(T), ==, 0));
		修改全局变量(T, 减, 1);
		开始持续治疗(事件玩家, 事件玩家, 120, 100);
		设置终极技能充能(事件玩家, 100);
		设置受到伤害(事件玩家, 50);
		开始伤害调整(事件玩家, 事件玩家, 200, 受伤害者，伤害者及伤害百分比);
		大字体信息(所有玩家(所有队伍), 字符串("{0}！", 字符串("{0} {1} {2}", 所用英雄(事件玩家), 字符串("已解锁", 无, 无, 无), 字符串("最终形态", 无, 无, 无)), 无, 无));
		设置移动速度(事件玩家, 150);
		小字体信息(事件玩家, 字符串("{0} {1}", 字符串("剩余", 无, 无, 无), 全局变量(T), 无));
	}
}

规则("【天使】使用复活受到灼烧效果，每秒伤害 10 点，持续 7 秒")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		天使;
	}

	条件
	{
		正在使用技能 2(事件玩家) == 真;
	}

	动作
	{
		设置状态(事件玩家, 选择英雄的玩家(英雄(黑影), 队伍1), 点燃, 7);
		开始持续伤害(事件玩家, 无, 7, 10);
	}
}

