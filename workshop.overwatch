规则("【死神】死亡绽放将附近的敌人拉向中心")
{
	事件
	{
		持续 - 每名玩家;
		队伍2;
		全部;
	}

	条件
	{
		正在使用终极技能(选择英雄的玩家(英雄(死神), 队伍1)) == 真;
		相距距离(事件玩家, 选择英雄的玩家(英雄(死神), 队伍1)) <= 8;
		在视线内(事件玩家, 选择英雄的玩家(英雄(死神), 队伍1), 敌方屏障阻挡视线) == 真;
		与(非(具有状态(事件玩家, 无敌)), 具有状态(事件玩家, 消散)) == 真;
	}

	动作
	{
		开始加速(事件玩家, 方向(事件玩家, 选择英雄的玩家(英雄(死神), 队伍1)), 100, 40, 至地图, 方向，速率，及最大速度);
		等待(0.160, 无视条件);
		如条件为”真“则循环;
		停止加速(事件玩家);
	}
}

规则("【死神】幽灵形态隐身")
{
	事件
	{
		持续 - 每名玩家;
		队伍1;
		死神;
	}

	条件
	{
		正在使用技能 1(事件玩家) == 真;
	}

	动作
	{
		设置不可见(事件玩家, 敌人);
		等待(3.500, 无视条件);
		设置不可见(事件玩家, 无);
	}
}

