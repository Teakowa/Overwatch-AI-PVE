{
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "build": "overpy compile -i src/main.opy --root src -o workshop.ow -l zh-CN",
    "build:release": "mkdir -p build && overpy compile -i src/main.opy --root src -l zh-CN -o build/main.ow",
    "build:release:all": "pnpm run build:release && pnpm run build:aram",
    "build:aram": "mkdir -p build && overpy compile -i src/aramMain.opy --root src -l zh-CN -o build/aram.ow",
    "perf:scan": "node tools/perf-loop-scan.mjs src",
    "perf:scan:strict": "node tools/perf-loop-scan.mjs --strict src",
    "tool:bump-version": "tsx tools/bump-version.ts",
    "tool:check-contracts": "tsx tools/check-contracts.ts",
    "tool:check-aram-overrides-duplicates": "tsx tools/check-aram-overrides-duplicates.ts",
    "tool:hero-pipeline": "tsx tools/hero-pipeline.ts",
    "tool:changelog-sync": "tsx tools/changelog-sync.ts",
    "tool:module-metrics-sync": "tsx tools/module-metrics-sync.ts",
    "tool:player-constants-reachability": "tsx tools/player-constants-reachability.ts",
    "tool:fandom:fetch-heroes": "tsx tools/fandom/fetch-heroes.ts",
    "tool:fandom:fetch-hero-details": "tsx tools/fandom/fetch-hero-details.ts",
    "tool:fandom:fetch-all-hero-details": "tsx tools/fandom/fetch-all-hero-details.ts"
  },
  "dependencies": {
    "overpy": "9.7.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
