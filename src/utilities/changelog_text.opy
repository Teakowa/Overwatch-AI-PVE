    ChangelogBodyTable[Hero.TRACER] = "\r\n●{0}\r\n*造成伤害 +60%\r\n*受到伤害 -65%\r\n*回溯 立刻回复50生命值\r\n  回溯期间完成击杀时回满闪现并重置回溯冷却\r\n*重生 阵亡后立刻重生\r\n*脉冲炸弹 充能速度 +60%\n\n※※离开重生室隐藏".format(Hero.TRACER)
    ChangelogBodyTable[Hero.VENDETTA] = "\r\n●{0}\r\n*造成伤害 +35%\r\n*受到伤害-45%\r\n{1}\r\n{2}\n\n※※离开重生室隐藏".format(Hero.VENDETTA, "{0} 暴击额外其{1}%最大生命值伤害，并回复{2}最大生命值".format(abilityIconString(Hero.VENDETTA, Button.PRIMARY_FIRE), VendettaBuff[0] * 100, VendettaBuff[6] * 100), "{0}\r\n{1}\r\n{2}".format("{0} 每命中一名敌人回复{1}%已损失生命值".format(abilityIconString(Hero.VENDETTA, Button.ABILITY_1), VendettaBuff[2] * 100), "{0} 使敌人沉默，持续期间不可阻挡".format(abilityIconString(Hero.VENDETTA, Button.ABILITY_2)), "{0} 击倒敌人，生命值低于{1}%的敌人将被斩杀".format(abilityIconString(Hero.VENDETTA, Button.ULTIMATE), VendettaBuff[5] * 100)))
    ChangelogBodyTable[Hero.VENTURE] = "\r\n●{0}\r\n*造成伤害 +40%\r\n*受到伤害 -30%\r\n钻地  \r\n  持续时间 +300%\r\n  移动速度 +156%\r\n钻头突刺 冷却时间 -25%\n\n※※离开重生室隐藏".format(Hero.VENTURE)
    ChangelogBodyTable[Hero.WIDOWMAKER] = "\r\n●{0}\r\n*造成伤害 +35%\r\n*受到伤害 +15%\r\n*移除开镜伤害衰减\n\n※※离开重生室隐藏".format(Hero.WIDOWMAKER)
    ChangelogBodyTable[Hero.WINSTON] = "\r\n●{0}\r\n*受到伤害 -35%\r\n*造成伤害 +10%\r\n{1} 特斯拉炮-集束电击\r\n  回复已造成伤害的生命值并额外造成目标最大生命值{2}%伤害\r\n{3} 屏障发射器\r\n  冷却时间降低至12秒\n\n※※离开重生室隐藏".format(Hero.WINSTON, abilityIconString(Hero.WINSTON, Button.SECONDARY_FIRE), WinstonBuff[0], abilityIconString(Hero.WINSTON, Button.ABILITY_2))
    ChangelogBodyTable[Hero.WRECKING_BALL] = "\r\n●{0}\r\n*造成伤害 +35%\r\n*受到伤害 -15%\r\n*工程抓钩\r\n  冷却时间降低至4秒\r\n  在重生室中无冷却时间\r\n*感应护盾 冷却时间降低至12秒\r\n*重力坠击 冷却时间降低至6秒\n\n※※离开重生室隐藏".format(Hero.WRECKING_BALL)
    ChangelogBodyTable[Hero.WUYANG] = "\r\n●{0}\r\n*水珠爆炸附带目标最大生命值8%额外伤害\r\n 并使{1}CD-1秒\r\n{2} 飞流步 回复{3}生命值 减伤{4}%\r\n{1} 翻江浪 对同一目标命中2次后冻结{5}秒\r\n{6} 惊涛破 使友方回复满生命值\n\n※※离开重生室隐藏".format(Hero.WUYANG, abilityIconString(Hero.WUYANG, Button.ABILITY_2), abilityIconString(Hero.WUYANG, Button.ABILITY_1), 4.5 * WuyangBuff[2], WuyangBuff[3], WUYANG_ABILITY2_FROZEN_DURATION, abilityIconString(Hero.WUYANG, Button.ULTIMATE))
    ChangelogBodyTable[Hero.ZARYA] = "\r\n●{0}\r\n*造成伤害 +35%\r\n*受到伤害 -25%\r\n*胜利意志\r\n  生命值低于30%时触发\r\n  获得1秒无敌并重置屏障冷却\r\n  回复{1}生命值\r\n{2} 粒子屏障\r\n  冷却时间降低至约9秒\r\n{3} 投射屏障\r\n  为目标提供3秒50点临时生命值\r\n*重力喷涌\r\n  充能速度提高8%\n\n※※离开重生室隐藏".format(Hero.ZARYA, ZaryaBuff[1] * ZaryaBuff[2], abilityIconString(Hero.ZARYA, Button.ABILITY_1), abilityIconString(Hero.ZARYA, Button.ABILITY_2))
    ChangelogBodyTable[Hero.ZENYATTA] = "\r\n●{0}\r\n*造成伤害 +60%\r\n*弹道速度 +25%\r\n*暴击倍率提高至 ×{1}\r\n*蹬 将敌人击退并让禅雅塔向反方向弹开\r\n*圣 治疗量提高至400/s 移速+25%\r\n  无法被命中 免疫所有控制\n\n※※离开重生室隐藏".format(Hero.ZENYATTA, 1 + HeadshotDamage[0])
