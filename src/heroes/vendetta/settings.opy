#!mainFile "../../main.opy"

macro INIT_VENDETTA_WORKSHOP_SETTINGS():
    VendettaBuff[0] = createWorkshopSettingInt("英雄：斩仇", "帕拉蒂尼之牙：暴击造成额外最大生命值伤害 %", VENDETTA_CRIT_MAX_HEALTH_DAMAGE_PERCENT_DEFAULT, VENDETTA_CRIT_MAX_HEALTH_DAMAGE_PERCENT_MIN, VENDETTA_CRIT_MAX_HEALTH_DAMAGE_PERCENT_MAX, 150)
    VendettaBuff[1] = createWorkshopSettingInt("英雄：斩仇", "帕拉蒂尼之牙：暴击对护甲造成额外最大生命值伤害 %", VENDETTA_CRIT_ARMOR_MAX_HEALTH_DAMAGE_PERCENT_DEFAULT, VENDETTA_CRIT_ARMOR_MAX_HEALTH_DAMAGE_PERCENT_MIN, VENDETTA_CRIT_ARMOR_MAX_HEALTH_DAMAGE_PERCENT_MAX, 150)
    VendettaBuff[2] = createWorkshopSettingInt("英雄：斩仇", "旋风疾步：命中敌人回复已损失生命值 %", VENDETTA_WHIRLWIND_HEAL_PERCENT_DEFAULT, VENDETTA_WHIRLWIND_HEAL_PERCENT_MIN, VENDETTA_WHIRLWIND_HEAL_PERCENT_MAX, 152) / 100
    VendettaBuff[3] = createWorkshopSettingInt("英雄：斩仇", "旋风疾步：对护甲造成额外伤害", VENDETTA_WHIRLWIND_ARMOR_BONUS_DAMAGE_DEFAULT, VENDETTA_WHIRLWIND_ARMOR_BONUS_DAMAGE_MIN, VENDETTA_WHIRLWIND_ARMOR_BONUS_DAMAGE_MAX, 153)
    VendettaBuff[4] = createWorkshopSettingFloat("英雄：斩仇", "斩地巨剑：击倒持续时间", VENDETTA_GREATSWORD_KNOCKDOWN_DURATION_DEFAULT, VENDETTA_GREATSWORD_KNOCKDOWN_DURATION_MIN, VENDETTA_GREATSWORD_KNOCKDOWN_DURATION_MAX, 154)
    VendettaBuff[5] = createWorkshopSettingInt("英雄：斩仇", "斩地巨剑：斩杀阈值 %", VENDETTA_EXECUTE_THRESHOLD_PERCENT_DEFAULT, VENDETTA_EXECUTE_THRESHOLD_PERCENT_MIN, VENDETTA_EXECUTE_THRESHOLD_PERCENT_MAX, 155)
    VendettaBuff[6] = createWorkshopSettingInt("英雄：斩仇", "帕拉蒂尼之牙：暴击回复最大生命值 %", VENDETTA_CRIT_HEAL_PERCENT_DEFAULT, VENDETTA_CRIT_HEAL_PERCENT_MIN, VENDETTA_CRIT_HEAL_PERCENT_MAX, 150)

