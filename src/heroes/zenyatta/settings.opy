#!mainFile "../../main.opy"

macro INIT_ZENYATTA_WORKSHOP_SETTINGS():
    Zen_KnockupStrength = createWorkshopSettingFloat("英雄：禅雅塔", "无影脚击退距离", ZENYATTA_MELEE_KNOCKBACK_DISTANCE_DEFAULT, ZENYATTA_MELEE_KNOCKBACK_DISTANCE_MIN, ZENYATTA_MELEE_KNOCKBACK_DISTANCE_MAX, 71)
    HeadshotDamage[0] = createWorkshopSettingFloat("暴击倍率", "禅雅塔：暴击倍率（以下实际数值将被除以100）", ZENYATTA_HEADSHOT_MULTIPLIER_PERCENT_DEFAULT, ZENYATTA_HEADSHOT_MULTIPLIER_PERCENT_MIN, ZENYATTA_HEADSHOT_MULTIPLIER_PERCENT_MAX, 70) / 100
