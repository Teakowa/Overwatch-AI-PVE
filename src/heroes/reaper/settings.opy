#!mainFile "../../main.opy"

macro INIT_REAPER_WORKSHOP_SETTINGS():
    ReaperBuff[0] = createWorkshopSettingInt("英雄：死神", "收割：击杀获得灵魂层数", REAPER_REAP_SOULS_ON_KILL_DEFAULT, REAPER_REAP_SOULS_ON_KILL_MIN, REAPER_REAP_SOULS_ON_KILL_MAX, 119)
    ReaperBuff[1] = createWorkshopSettingFloat("英雄：死神", "收割：每层灵魂减少技能冷却", REAPER_SOUL_COOLDOWN_REDUCTION_DEFAULT, REAPER_SOUL_COOLDOWN_REDUCTION_MIN, REAPER_SOUL_COOLDOWN_REDUCTION_MAX, 119)
    ReaperBuff[2] = createWorkshopSettingInt("英雄：死神", "幽灵形态：基础伤害增幅 %", REAPER_WRAITH_BASE_DAMAGE_PERCENT_DEFAULT, REAPER_WRAITH_BASE_DAMAGE_PERCENT_MIN, REAPER_WRAITH_BASE_DAMAGE_PERCENT_MAX, 119)
    ReaperBuff[3] = createWorkshopSettingInt("英雄：死神", "幽灵形态：灵魂层数提供伤害增幅 %", REAPER_WRAITH_DAMAGE_PER_SOUL_PERCENT_DEFAULT, REAPER_WRAITH_DAMAGE_PER_SOUL_PERCENT_MIN, REAPER_WRAITH_DAMAGE_PER_SOUL_PERCENT_MAX, 119)
    ReaperBuff[4] = createWorkshopSettingInt("英雄：死神", "暗影步：基础伤害减免 %", REAPER_SHADOW_STEP_BASE_DAMAGE_REDUCTION_PERCENT_DEFAULT, REAPER_SHADOW_STEP_BASE_DAMAGE_REDUCTION_PERCENT_MIN, REAPER_SHADOW_STEP_BASE_DAMAGE_REDUCTION_PERCENT_MAX, 119)
    ReaperBuff[5] = createWorkshopSettingInt("英雄：死神", "暗影步：灵魂层数提供伤害减免 %", REAPER_SHADOW_STEP_DAMAGE_REDUCTION_PER_SOUL_PERCENT_DEFAULT, REAPER_SHADOW_STEP_DAMAGE_REDUCTION_PER_SOUL_PERCENT_MIN, REAPER_SHADOW_STEP_DAMAGE_REDUCTION_PER_SOUL_PERCENT_MAX, 119)
    ReaperBuff[6] = createWorkshopSettingFloat("英雄：死神", "恐怖扳机：冷却时间", REAPER_DREAD_TRIGGER_COOLDOWN_DEFAULT, REAPER_DREAD_TRIGGER_COOLDOWN_MIN, REAPER_DREAD_TRIGGER_COOLDOWN_MAX, 119)
    ReaperBuff[7] = createWorkshopSettingFloat("英雄：死神", "恐怖扳机：基于灵魂层数造成流血伤害", REAPER_DREAD_TRIGGER_BLEED_PER_SOUL_DEFAULT, REAPER_DREAD_TRIGGER_BLEED_PER_SOUL_MIN, REAPER_DREAD_TRIGGER_BLEED_PER_SOUL_MAX, 119) / 2
    ReaperBuff[8] = createWorkshopSettingInt("英雄：死神", "死亡绽放：灵魂层数提供伤害增幅 %", REAPER_DEATH_BLOSSOM_DAMAGE_PER_SOUL_PERCENT_DEFAULT, REAPER_DEATH_BLOSSOM_DAMAGE_PER_SOUL_PERCENT_MIN, REAPER_DEATH_BLOSSOM_DAMAGE_PER_SOUL_PERCENT_MAX, 119)

