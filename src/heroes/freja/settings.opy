#!mainFile "../../main.opy"

macro INIT_FREJA_WORKSHOP_SETTINGS():
    FrejaBuff[0] = createWorkshopSettingInt("英雄：弗蕾娅", "无情猎杀：每层伤害", FREJA_RELENTLESS_HUNT_DAMAGE_PER_STACK_DEFAULT, FREJA_RELENTLESS_HUNT_DAMAGE_PER_STACK_MIN, FREJA_RELENTLESS_HUNT_DAMAGE_PER_STACK_MAX, 133)
    FrejaBuff[1] = createWorkshopSettingInt("英雄：弗蕾娅", "无情猎杀：最大生命值百分比伤害", FREJA_RELENTLESS_HUNT_MAX_HEALTH_DAMAGE_PERCENT_DEFAULT, FREJA_RELENTLESS_HUNT_MAX_HEALTH_DAMAGE_PERCENT_MIN, FREJA_RELENTLESS_HUNT_MAX_HEALTH_DAMAGE_PERCENT_MAX, 134)
    FrejaBuff[2] = createWorkshopSettingInt("英雄：弗蕾娅", "无情猎杀：斩杀阈值", FREJA_EXECUTE_THRESHOLD_PERCENT_DEFAULT, FREJA_EXECUTE_THRESHOLD_PERCENT_MIN, FREJA_EXECUTE_THRESHOLD_PERCENT_MAX, 135)

