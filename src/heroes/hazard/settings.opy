#!mainFile "../../main.opy"

macro INIT_HAZARD_WORKSHOP_SETTINGS():
    HazardBuff[0] = createWorkshopSettingInt("英雄：骇灾", "尖刺护体：基于受到伤害的额外伤害 %", HAZARD_SPIKED_GUARD_DAMAGE_SCALAR_PERCENT_DEFAULT, HAZARD_SPIKED_GUARD_DAMAGE_SCALAR_PERCENT_MIN, HAZARD_SPIKED_GUARD_DAMAGE_SCALAR_PERCENT_MAX, 70) / 100
    HazardBuff[1] = createWorkshopSettingFloat("英雄：骇灾", "灾厄馈赠（被动）：基于受到伤害获得终极技能充能 %", HAZARD_PASSIVE_ULT_CHARGE_PERCENT_DEFAULT, HAZARD_PASSIVE_ULT_CHARGE_PERCENT_MIN, HAZARD_PASSIVE_ULT_CHARGE_PERCENT_MAX, 70)
    HazardBuff[2] = createWorkshopSettingInt("英雄：骇灾", "灾厄馈赠（被动）：基于受到原始伤害（未被减伤）回复生命值 %", HAZARD_PASSIVE_HEAL_PERCENT_DEFAULT, HAZARD_PASSIVE_HEAL_PERCENT_MIN, HAZARD_PASSIVE_HEAL_PERCENT_MAX, 70) / 100

