#!mainFile "../../main.opy"

macro INIT_BRIGITTE_WORKSHOP_SETTINGS():
    Brigitte[1] = createWorkshopSettingInt("英雄：布丽吉塔", "恢复包：提供的护甲", BRIGITTE_REPAIR_PACK_ARMOR_DEFAULT, BRIGITTE_REPAIR_PACK_ARMOR_MIN, BRIGITTE_REPAIR_PACK_ARMOR_MAX, 30)
    Brigitte[3] = createWorkshopSettingInt("英雄：布丽吉塔", "能量盾击：使敌人减速 %", BRIGITTE_SHIELD_BASH_SLOW_PERCENT_DEFAULT, BRIGITTE_SHIELD_BASH_SLOW_PERCENT_MIN, BRIGITTE_SHIELD_BASH_SLOW_PERCENT_MAX, 31)
    Brigitte[2] = createWorkshopSettingInt("英雄：布丽吉塔", "集结号令：每秒额外护甲", BRIGITTE_RALLY_ARMOR_PER_SECOND_DEFAULT, BRIGITTE_RALLY_ARMOR_PER_SECOND_MIN, BRIGITTE_RALLY_ARMOR_PER_SECOND_MAX, 34)
    Brigitte[0] = createWorkshopSettingInt("英雄：布丽吉塔", "集结号令：每秒伤害减免", BRIGITTE_RALLY_DAMAGE_REDUCTION_DEFAULT, BRIGITTE_RALLY_DAMAGE_REDUCTION_MIN, BRIGITTE_RALLY_DAMAGE_REDUCTION_MAX, 33)

