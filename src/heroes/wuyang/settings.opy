#!mainFile "../../main.opy"

macro INIT_WUYANG_WORKSHOP_SETTINGS():
    WuyangBuff[0] = createWorkshopSettingInt("英雄：无漾", "玄武杖：水珠爆炸减速 %", WUYANG_WATER_ORB_SLOW_PERCENT_DEFAULT, WUYANG_WATER_ORB_SLOW_PERCENT_MIN, WUYANG_WATER_ORB_SLOW_PERCENT_MAX, 136)
    WuyangBuff[1] = createWorkshopSettingInt("英雄：无漾", "养神泉：泉水提供的额外护盾", WUYANG_SPRING_EXTRA_SHIELDS_DEFAULT, WUYANG_SPRING_EXTRA_SHIELDS_MIN, WUYANG_SPRING_EXTRA_SHIELDS_MAX, 137)
    WuyangBuff[2] = createWorkshopSettingInt("英雄：无漾", "飞流步：每秒自我治疗", WUYANG_FLOW_STEP_SELF_HEAL_PER_SECOND_DEFAULT, WUYANG_FLOW_STEP_SELF_HEAL_PER_SECOND_MIN, WUYANG_FLOW_STEP_SELF_HEAL_PER_SECOND_MAX, 138)
    WuyangBuff[3] = createWorkshopSettingInt("英雄：无漾", "飞流步：伤害减免", WUYANG_FLOW_STEP_DAMAGE_REDUCTION_PERCENT_DEFAULT, WUYANG_FLOW_STEP_DAMAGE_REDUCTION_PERCENT_MIN, WUYANG_FLOW_STEP_DAMAGE_REDUCTION_PERCENT_MAX, 139)
    WuyangBuff[4] = createWorkshopSettingInt("英雄：无漾", "惊涛波：爆炸减速 %", WUYANG_WAVE_BLAST_SLOW_PERCENT_DEFAULT, WUYANG_WAVE_BLAST_SLOW_PERCENT_MIN, WUYANG_WAVE_BLAST_SLOW_PERCENT_MAX, 140)
    WuyangBuff[5] = createWorkshopSettingInt("英雄：无漾", "惊涛波：友方每秒额外生命值回复 %", WUYANG_WAVE_BLAST_ALLY_HEAL_PERCENT_DEFAULT, WUYANG_WAVE_BLAST_ALLY_HEAL_PERCENT_MIN, WUYANG_WAVE_BLAST_ALLY_HEAL_PERCENT_MAX, 141) / 100

