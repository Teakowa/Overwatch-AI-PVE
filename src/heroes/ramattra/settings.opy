#!mainFile "../../main.opy"

macro INIT_RAMATTRA_WORKSHOP_SETTINGS():
    Ram_Annihilation[0] = createWorkshopSettingInt("英雄：拉玛刹", "天罚形态：铁臂：最大临时生命值", RAMATTRA_NEMESIS_MAX_OVERHEALTH_DEFAULT, RAMATTRA_NEMESIS_MAX_OVERHEALTH_MIN, RAMATTRA_NEMESIS_MAX_OVERHEALTH_MAX, 100)
    Ram_Annihilation[1] = createWorkshopSettingInt("英雄：拉玛刹", "诛 （终极技能）基于已造成伤害的百分比回复 ", RAMATTRA_ANNIHILATION_HEAL_PERCENT_DEFAULT, RAMATTRA_ANNIHILATION_HEAL_PERCENT_MIN, RAMATTRA_ANNIHILATION_HEAL_PERCENT_MAX, 101) / 100
    Ram_Annihilation[2] = createWorkshopSettingInt("英雄：拉玛刹", "诛 （终极技能）额外造成伤害 %", RAMATTRA_ANNIHILATION_DAMAGE_PERCENT_DEFAULT, RAMATTRA_ANNIHILATION_DAMAGE_PERCENT_MIN, RAMATTRA_ANNIHILATION_DAMAGE_PERCENT_MAX, 101)
    Ram_Annihilation[3] = createWorkshopSettingInt("英雄：拉玛刹", "诛 （终极技能）移动速度加成 %", RAMATTRA_ANNIHILATION_MOVE_SPEED_PERCENT_DEFAULT, RAMATTRA_ANNIHILATION_MOVE_SPEED_PERCENT_MIN, RAMATTRA_ANNIHILATION_MOVE_SPEED_PERCENT_MAX, 102)
    Ram_Annihilation[4] = createWorkshopSettingInt("英雄：拉玛刹", "诛 （终极技能）受到伤害减免 %", RAMATTRA_ANNIHILATION_DAMAGE_REDUCTION_PERCENT_DEFAULT, RAMATTRA_ANNIHILATION_DAMAGE_REDUCTION_PERCENT_MIN, RAMATTRA_ANNIHILATION_DAMAGE_REDUCTION_PERCENT_MAX, 103)
